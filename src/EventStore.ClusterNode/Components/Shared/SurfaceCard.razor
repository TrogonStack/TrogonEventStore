<article class="group flex h-full flex-col rounded-[1.75rem] border border-white/80 bg-white/80 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)] backdrop-blur transition duration-200 hover:-translate-y-1 hover:border-es-green/30 hover:shadow-[0_28px_90px_rgba(23,32,51,0.14)]">
	@if (!string.IsNullOrWhiteSpace(Eyebrow))
	{
		<p class="mb-3 text-xs font-black uppercase tracking-[0.24em] text-es-green">@Eyebrow</p>
	}
	<h2 class="text-2xl font-black tracking-tight text-es-ink">@Title</h2>
	<p class="mt-3 flex-1 text-base leading-7 text-es-muted">@Description</p>
	@if (ChildContent is not null)
	{
		<div class="mt-5">
			@ChildContent
		</div>
	}
	@if (!string.IsNullOrWhiteSpace(Href))
	{
		<a class="mt-6 inline-flex w-fit items-center rounded-full bg-es-ink px-4 py-2 text-sm font-bold text-white transition group-hover:bg-es-green" href="@Href">
			@LinkText
			<span aria-hidden="true" class="ml-2">-&gt;</span>
		</a>
	}
</article>

@code {
	[Parameter] public string Eyebrow { get; set; } = "";
	[Parameter] public string Title { get; set; } = "";
	[Parameter] public string Description { get; set; } = "";
	[Parameter] public string Href { get; set; } = "";
	[Parameter] public string LinkText { get; set; } = "Open";
	[Parameter] public RenderFragment ChildContent { get; set; }
}
