<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
	<p class="text-sm font-black uppercase tracking-[0.22em] text-es-green">Node action</p>
	<h2 class="mt-3 text-xl font-black tracking-tight text-es-ink">@Title</h2>
	<p class="mt-3 text-sm leading-6 text-es-muted">@Description</p>
	<form class="mt-5" method="post" action="@Action" data-admin-command data-confirm="@Confirm">
		<button class="rounded-2xl bg-es-ink px-5 py-3 text-sm font-black text-white shadow-lg shadow-es-ink/15 transition hover:bg-es-green" type="submit">@ButtonText</button>
	</form>
</article>

@code {
	[Parameter] public string Title { get; set; } = "";
	[Parameter] public string Description { get; set; } = "";
	[Parameter] public string Action { get; set; } = "";
	[Parameter] public string ButtonText { get; set; } = "Run";
	[Parameter] public string Confirm { get; set; } = "";
}
