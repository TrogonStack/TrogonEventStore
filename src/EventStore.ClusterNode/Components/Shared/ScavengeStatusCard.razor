<article class="rounded-[1.5rem] border border-es-ink/10 bg-white/70 p-5">
	<div class="flex flex-wrap items-center justify-between gap-2">
		<h3 class="font-black text-es-ink">@Title</h3>
		<StatusBadge Label="@Status.Status" Tone="@Status.Tone" />
	</div>
	@if (!Status.IsAvailable)
	{
		<p class="mt-3 text-sm leading-6 text-red-700">@Status.Message</p>
	}
	else if (Status.HasScavenge)
	{
		<a class="mt-3 inline-flex break-all font-mono text-sm font-bold text-es-forest hover:text-es-green" href="@Status.DetailHref">@Status.ScavengeId</a>
	}
	else
	{
		<p class="mt-3 text-sm leading-6 text-es-muted">@Status.Result</p>
	}
</article>

@code {
	[Parameter] public string Title { get; set; } = "";
	[Parameter] public ScavengeStatusView Status { get; set; } = ScavengeStatusView.Unavailable("Not loaded.");
}
