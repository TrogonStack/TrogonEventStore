@page "/ui/users/{LoginName}/edit"
@inject UserBrowserService UserBrowser
@inject NavigationManager Navigation
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Edit User - EventStore UI</PageTitle>

<section class="max-w-5xl">
	<a class="text-sm font-bold text-es-green transition hover:text-es-forest" href="@($"/ui/users/{Uri.EscapeDataString(LoginName)}")">Back to user</a>
	<p class="mt-6 text-sm font-black uppercase tracking-[0.28em] text-es-green">Edit user</p>
	<h1 class="mt-4 break-words text-5xl font-black tracking-tight text-es-ink sm:text-6xl">@LoginName</h1>
	<p class="mt-5 text-lg leading-8 text-es-muted">Update the display name and built-in role assignment for this internal account.</p>
</section>

@if (Page is null)
{
	<section class="mt-8 rounded-[2rem] border border-white/80 bg-white/80 p-6 text-es-muted shadow-[0_18px_60px_rgba(23,32,51,0.08)]">
		Loading user...
	</section>
}
else if (Page.User is null)
{
	<section class="mt-8 rounded-[2rem] border border-white/80 bg-white/80 p-6 text-es-muted shadow-[0_18px_60px_rgba(23,32,51,0.08)]">
		@Page.Message
	</section>
}
else
{
	<section class="mt-8 grid gap-5 lg:grid-cols-[1.1fr_0.9fr]">
		<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
			<EditForm Model="Input" FormName="user-edit" OnValidSubmit="UpdateUser">
				<AntiforgeryToken />
				<DataAnnotationsValidator />
				<InputText type="hidden" @bind-Value="Input.LoginName" />

				<div class="grid gap-4">
					<div class="rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4">
						<p class="text-xs font-black uppercase tracking-[0.18em] text-es-muted">Login name</p>
						<p class="mt-2 break-words font-mono text-sm font-bold text-es-ink">@Page.User.LoginName</p>
					</div>
					<label class="text-sm font-bold text-es-muted">
						Full name
						<InputText class="mt-2 w-full rounded-2xl border border-es-ink/10 bg-white px-4 py-3 text-es-ink outline-none transition focus:border-es-green focus:ring-4 focus:ring-es-green/15" @bind-Value="Input.FullName" />
						<ValidationMessage For="() => Input.FullName" />
					</label>
				</div>

				<div class="mt-5 rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4">
					<p class="text-xs font-black uppercase tracking-[0.18em] text-es-muted">Role</p>
					<InputRadioGroup class="mt-3 grid gap-2 sm:grid-cols-3" @bind-Value="Input.Role">
						@foreach (var option in UserBrowserService.RoleOptions)
						{
							<label class="flex items-center gap-2 rounded-2xl border border-es-ink/10 bg-white px-3 py-2 text-sm font-bold text-es-ink">
								<InputRadio Value="@option.Value" />
								@option.Label
							</label>
						}
					</InputRadioGroup>
				</div>

				@if (Result is not null)
				{
					<p class="mt-5 rounded-2xl border @(Result.Success ? "border-es-green/25 bg-es-green/10 text-es-forest" : "border-red-200 bg-red-50 text-red-800") p-4 text-sm font-bold">@Result.Message</p>
				}

				<div class="mt-5 flex flex-wrap gap-2">
					<button class="rounded-2xl bg-es-ink px-5 py-3 text-sm font-black text-white shadow-lg shadow-es-ink/15 transition hover:bg-es-green" type="submit">Update user</button>
					<a class="rounded-2xl border border-es-ink/10 bg-white px-5 py-3 text-sm font-black text-es-ink transition hover:border-es-green/30 hover:text-es-forest" href="@Page.User.DetailHref">Cancel</a>
				</div>
			</EditForm>
		</article>

		<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
			<StatusBadge Label="@Page.User.StatusLabel" Tone="@Page.User.StatusTone" />
			<h2 class="mt-4 text-2xl font-black tracking-tight text-es-ink">Current account state</h2>
			<p class="mt-3 break-words text-sm leading-6 text-es-muted">@Page.User.GroupsLabel</p>
			<p class="mt-4 font-mono text-xs text-es-muted">@Page.User.UpdatedLabel</p>
		</article>
	</section>
}

@code {
	[Parameter] public string LoginName { get; set; } = "";

	[SupplyParameterFromForm(FormName = "user-edit")]
	private UserEditInput Input { get; set; } = new();

	private UserDetailPage Page { get; set; }
	private UserCommandResult Result { get; set; }

	protected override async Task OnParametersSetAsync() {
		var requested = LoginName;
		var hasSubmittedForm = string.Equals(Input.LoginName, requested, StringComparison.OrdinalIgnoreCase);
		Page = null;
		Result = null;
		if (!hasSubmittedForm)
			Input = new();

		try {
			var page = await UserBrowser.Read(requested);
			if (requested != LoginName)
				return;

			Page = page;
			if (Page.User is not null) {
				Input.LoginName = Page.User.LoginName;
				if (!hasSubmittedForm) {
					Input.FullName = Page.User.FullName;
					Input.Role = Page.User.SelectedRole;
				}
			}
		} catch (OperationCanceledException) {
			throw;
		} catch (Exception ex) {
			if (requested == LoginName)
				Page = UserDetailPage.Unavailable(requested, UserBrowser.ReadCurrentRequest(), $"Failed to load user: {UserInterfaceMessages.Friendly(ex)}");
		}
	}

	private async Task UpdateUser() {
		if (Page?.User is not { } user) {
			Result = UserCommandResult.Failure(LoginName, "User details are not loaded.");
			return;
		}

		var loginName = user.LoginName;
		var redirectTo = "";
		try {
			Result = await UserBrowser.Update(new UserUpdateRequest(loginName, Input.FullName, Input.Role));
			if (Result.Success)
				redirectTo = $"/ui/users/{Uri.EscapeDataString(Result.LoginName)}";
		} catch (OperationCanceledException) {
			Result = UserCommandResult.Failure(loginName, "User update was canceled.");
		} catch (Exception ex) {
			Result = UserCommandResult.Failure(loginName, $"Failed to update user: {UserInterfaceMessages.Friendly(ex)}");
		}

		if (!string.IsNullOrWhiteSpace(redirectTo))
			Navigation.NavigateTo(redirectTo);
	}

	private sealed class UserEditInput {
		public string LoginName { get; set; } = "";

		[Required(ErrorMessage = "Enter a full name.")]
		public string FullName { get; set; } = "";

		public string Role { get; set; } = "";
	}
}
