@page "/ui/streams/delete/{*StreamId}"
@using EventStore.ClusterNode.Components.Services
@using Microsoft.AspNetCore.Components.Forms
@inject StreamBrowserService Streams

<PageTitle>Delete Stream - EventStore UI</PageTitle>

<section class="max-w-5xl">
	<a class="text-sm font-bold text-es-green transition hover:text-es-forest" href="@($"/ui/streams/{Uri.EscapeDataString(StreamId)}")">&lt;- Back to stream</a>
	<p class="mt-6 text-sm font-black uppercase tracking-[0.28em] text-es-green">Delete stream</p>
	<h1 class="mt-4 break-words text-5xl font-black tracking-tight text-es-ink sm:text-6xl">@StreamId</h1>
	<p class="mt-5 text-lg leading-8 text-es-muted">Confirm stream deletion with hard delete kept explicit.</p>
</section>

<section class="mt-8 grid gap-5 lg:grid-cols-[1fr_0.9fr]">
	<article class="rounded-[2rem] border border-red-200 bg-red-50/80 p-6 shadow-[0_20px_70px_rgba(127,29,29,0.09)]">
		<h2 class="text-2xl font-black tracking-tight text-red-950">This changes stream availability.</h2>
		<p class="mt-3 text-sm leading-6 text-red-900">Soft delete hides the stream from normal reads. Hard delete is more final and should only be used when the operator intends that permanence.</p>

		<EditForm Model="Input" FormName="stream-delete" OnValidSubmit="Delete">
			<AntiforgeryToken />
			<InputCheckbox id="hardDelete" class="mt-5" @bind-Value="Input.HardDelete" />
			<label class="ml-2 text-sm font-bold text-red-950" for="hardDelete">Hard delete</label>

			@if (Result is not null)
			{
				<p class="mt-5 rounded-2xl border @(Result.Success ? "border-es-green/25 bg-es-green/10 text-es-forest" : "border-red-200 bg-white text-red-800") p-4 text-sm font-bold">@Result.Message</p>
			}

			<div class="mt-5 flex flex-wrap gap-2">
				<button class="rounded-2xl bg-red-900 px-5 py-3 text-sm font-black text-white shadow-lg shadow-red-900/15 transition hover:bg-red-800" type="submit">Delete stream</button>
				<a class="rounded-2xl border border-es-ink/10 bg-white px-5 py-3 text-sm font-black text-es-ink transition hover:border-es-green/30 hover:text-es-forest" href="@($"/ui/streams/{Uri.EscapeDataString(StreamId)}")">Cancel</a>
			</div>
		</EditForm>
	</article>

	<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
		<StatusBadge Label="Operator confirmation" Tone="warn" />
		<h2 class="mt-4 text-2xl font-black tracking-tight text-es-ink">After success</h2>
		<p class="mt-3 text-sm leading-6 text-es-muted">The page keeps the confirmation visible. Use the streams index to continue browsing after the command completes.</p>
		@if (Result?.Success == true)
		{
			<a class="mt-5 inline-flex rounded-2xl bg-es-ink px-5 py-3 text-sm font-black text-white shadow-lg shadow-es-ink/15 transition hover:bg-es-green" href="/ui/streams">Back to streams</a>
		}
	</article>
</section>

@code {
	[Parameter] public string StreamId { get; set; } = "";

	[SupplyParameterFromForm(FormName = "stream-delete")]
	private StreamDeleteInput Input { get; set; } = new();

	private StreamCommandResult Result { get; set; }

	private async Task Delete() {
		try {
			Result = await Streams.DeleteStream(StreamId, Input.HardDelete);
		} catch (OperationCanceledException) {
			Result = StreamCommandResult.Failure(StreamId, "Stream delete was canceled.");
		} catch (Exception ex) {
			Result = StreamCommandResult.Failure(StreamId, $"Failed to delete stream: {UserInterfaceMessages.Friendly(ex)}");
		}
	}

	private sealed class StreamDeleteInput {
		public bool HardDelete { get; set; }
	}
}
