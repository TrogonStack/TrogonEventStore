@page "/ui/users"
@inject UserBrowserService UserBrowser

<PageTitle>Users - EventStore UI</PageTitle>

<section class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
	<div>
		<p class="text-sm font-black uppercase tracking-[0.28em] text-es-green">Users</p>
		<h1 class="mt-4 text-5xl font-black tracking-tight text-es-ink sm:text-6xl">Manage account access.</h1>
		<p class="mt-5 text-lg leading-8 text-es-muted">Create users, adjust roles, reset passwords, and inspect the currently authenticated principal.</p>
		<div class="mt-6 flex flex-wrap gap-2">
			<a class="rounded-full bg-es-ink px-4 py-2 text-sm font-bold text-white shadow-lg shadow-es-ink/15 transition hover:bg-es-green" href="/ui/users/new">New user</a>
		</div>
	</div>
	<div class="grid gap-3 rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)] sm:grid-cols-2">
		<MetricCard Label="Users" Value="@(Page?.UserCountLabel ?? "-")" />
		<MetricCard Label="Enabled" Value="@(Page?.EnabledCountLabel ?? "-")" Tone="good" />
		<MetricCard Label="Disabled" Value="@(Page?.DisabledCountLabel ?? "-")" Tone="muted" />
		<MetricCard Label="Groups" Value="@(Page?.GroupCountLabel ?? "-")" Tone="muted" />
	</div>
</section>

<section class="mt-8 grid gap-5 lg:grid-cols-[0.8fr_1.2fr]">
	<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
		<div class="flex flex-wrap items-center gap-2">
			<StatusBadge Label="@(Page?.CurrentUser.AuthenticationLabel ?? "Loading")" Tone="@(Page?.CurrentUser.AuthenticationTone ?? "muted")" />
			<StatusBadge Label="Current request" Tone="muted" />
		</div>
		<h2 class="mt-4 text-3xl font-black tracking-tight text-es-ink">@(Page?.CurrentUser.NameLabel ?? "Loading user")</h2>
		<dl class="mt-5 grid gap-3 text-sm">
			<div class="rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4">
				<dt class="text-xs font-black uppercase tracking-[0.18em] text-es-muted">Authentication</dt>
				<dd class="mt-2 font-bold text-es-ink">@(string.IsNullOrWhiteSpace(Page?.CurrentUser.AuthenticationType) ? "Unknown" : Page.CurrentUser.AuthenticationType)</dd>
			</div>
			<div class="rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4">
				<dt class="text-xs font-black uppercase tracking-[0.18em] text-es-muted">Roles</dt>
				<dd class="mt-2 break-words text-es-ink">@(Page?.CurrentUser.RolesLabel ?? "Loading")</dd>
			</div>
		</dl>
	</article>

	@if (Page is null)
	{
		<div class="rounded-[2rem] border border-white/80 bg-white/80 p-6 text-es-muted shadow-[0_18px_60px_rgba(23,32,51,0.08)]">
			Loading users...
		</div>
	}
	else if (!Page.HasUsers)
	{
		<div class="rounded-[2rem] border border-white/80 bg-white/80 p-6 text-es-muted shadow-[0_18px_60px_rgba(23,32,51,0.08)]">
			@(string.IsNullOrWhiteSpace(Page.Message) ? "No users are available." : Page.Message)
		</div>
	}
	else
	{
		<div class="overflow-hidden rounded-[2rem] border border-white/80 bg-white/85 shadow-[0_20px_70px_rgba(23,32,51,0.09)]" data-admin-auto-refresh="5000">
			<div class="overflow-x-auto">
				<table class="min-w-full divide-y divide-es-ink/10 text-left text-sm">
					<thead class="bg-es-ink/5 text-xs font-black uppercase tracking-[0.16em] text-es-muted">
						<tr>
							<th class="px-5 py-4">User</th>
							<th class="px-5 py-4">Status</th>
							<th class="px-5 py-4">Groups</th>
							<th class="px-5 py-4">Updated</th>
							<th class="px-5 py-4">Actions</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-es-ink/10">
						@foreach (var user in Page.Users)
						{
							<tr class="align-top">
								<td class="px-5 py-4">
									<p class="font-black text-es-ink">@user.DisplayName</p>
									<p class="mt-1 font-mono text-xs text-es-muted">@user.LoginName</p>
								</td>
								<td class="px-5 py-4">
									<StatusBadge Label="@user.StatusLabel" Tone="@user.StatusTone" />
								</td>
								<td class="px-5 py-4 max-w-sm break-words text-es-muted">@user.GroupsLabel</td>
								<td class="px-5 py-4 font-mono text-xs text-es-muted">@user.UpdatedLabel</td>
								<td class="px-5 py-4">
									<div class="flex flex-wrap gap-2">
										<a class="rounded-full bg-es-ink px-3 py-1.5 text-xs font-bold text-white transition hover:bg-es-green" href="@user.DetailHref">Details</a>
										<a class="rounded-full border border-es-ink/10 bg-white px-3 py-1.5 text-xs font-bold text-es-ink transition hover:border-es-green/30 hover:text-es-forest" href="@user.EditHref">Edit</a>
										<a class="rounded-full border border-es-ink/10 bg-white px-3 py-1.5 text-xs font-bold text-es-ink transition hover:border-es-green/30 hover:text-es-forest" href="@user.ResetPasswordHref">Reset</a>
										@if (user.Disabled)
										{
											<a class="rounded-full border border-es-green/30 bg-es-green/10 px-3 py-1.5 text-xs font-bold text-es-forest transition hover:bg-es-green hover:text-white" href="@user.EnableHref">Enable</a>
										}
										else
										{
											<a class="rounded-full border border-amber-200 bg-amber-50 px-3 py-1.5 text-xs font-bold text-amber-900 transition hover:bg-amber-100" href="@user.DisableHref">Disable</a>
										}
									</div>
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>
	}
</section>

@code {
	private UserListPage Page { get; set; }

	protected override async Task OnParametersSetAsync() {
		Page = null;

		try {
			Page = await UserBrowser.ReadAll();
		} catch (OperationCanceledException) {
			throw;
		} catch (Exception ex) {
			Page = UserListPage.Unavailable(UserBrowser.ReadCurrentRequest(), $"Failed to load users: {UserInterfaceMessages.Friendly(ex)}");
		}
	}
}
