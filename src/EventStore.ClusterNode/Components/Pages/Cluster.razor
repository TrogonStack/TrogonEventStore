@page "/ui"
@page "/ui/cluster"
@inject QueueDashboardService QueueDashboard
@inject ClusterStatusService ClusterStatus
@inject NodeProbeService NodeProbes
@using System.Text
@using System.Globalization
@using EventStore.Core.Cluster
@using EventStore.Core.Data

<PageTitle>EventStore Cluster</PageTitle>

<div data-queue-dashboard="home">
<script type="application/json" data-queue-dashboard-payload>@((MarkupString)DashboardPayloadJson)</script>
<section id="cluster-status" class="mb-5 overflow-hidden rounded-[2rem] border border-white/80 bg-white/85 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
	<div class="flex flex-col gap-3 border-b border-es-ink/10 px-5 py-5 xl:flex-row xl:items-start xl:justify-between">
		<div>
			<p class="text-xs font-black uppercase tracking-[0.22em] text-es-green">Cluster status</p>
			<h1 class="mt-2 text-3xl font-black tracking-tight text-es-ink">Cluster membership</h1>
			<p class="mt-2 text-sm text-es-muted">State, checkpoints, node endpoints, and topology from the node membership view.</p>
		</div>
		<div class="flex flex-wrap gap-2">
			<span class="@ClusterStatusBadgeClass">@ClusterStatusLabel</span>
			<span class="rounded-full border border-es-ink/10 bg-white px-4 py-2 text-sm font-bold text-es-muted">@ClusterUpdatedLabel</span>
			<a class="rounded-full bg-es-ink px-4 py-2 text-sm font-bold text-white hover:bg-es-green hover:text-white" href="/ui/cluster">Refresh</a>
		</div>
	</div>

	<div class="grid gap-4 p-5 md:grid-cols-2 xl:grid-cols-4">
		<MetricCard Label="Members" Value="@MemberCountLabel" />
		<MetricCard Label="Alive" Value="@AliveCountLabel" Tone="muted" />
		<MetricCard Label="Leader" Value="@LeaderLabel" />
		<MetricCard Label="Read-only replicas" Value="@ReadOnlyCountLabel" Tone="muted" />
	</div>

	<div class="grid gap-5 px-5 pb-5 2xl:grid-cols-[1fr_0.55fr]">
		<div class="overflow-hidden rounded-[1.5rem] border border-es-ink/10 bg-white">
			<div class="overflow-x-auto">
				<table class="min-w-full text-left text-sm">
					<thead class="border-b border-es-ink/10 bg-es-ink/5 text-xs font-black uppercase tracking-[0.16em] text-es-muted">
						<tr>
							<th class="px-5 py-4">State</th>
							<th class="px-5 py-4">Status</th>
							<th class="px-5 py-4">Timestamp (UTC)</th>
							<th class="px-5 py-4">Checkpoints</th>
							<th class="px-5 py-4">TCP</th>
							<th class="px-5 py-4">HTTP</th>
							<th class="px-5 py-4 text-right">Actions</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-es-ink/10">
						@if (!ClusterMembers.Any())
						{
							<tr>
								<td class="px-5 py-4 text-es-muted" colspan="7">@ClusterEmptyMessage</td>
							</tr>
						}
						else
						{
							foreach (var member in ClusterMembers)
							{
								<tr class="@MemberRowClass(member)">
									<td class="px-5 py-4">
										<p class="@MemberStateClass(member)">@member.State</p>
										<p class="mt-1 max-w-[14rem] truncate font-mono text-xs text-es-muted">@member.InstanceId</p>
									</td>
									<td class="@MemberStatusClass(member)">@MemberStatus(member)</td>
									<td class="px-5 py-4 font-mono text-xs text-es-muted">@TimestampLabel(member.TimeStamp)</td>
									<td class="px-5 py-4 font-mono text-xs text-es-muted">
										@if (member.State == VNodeState.Manager)
										{
											<span>n/a</span>
										}
										else
										{
											<p>@CheckpointLabel(member)</p>
											<p class="mt-1">@EpochLabel(member)</p>
										}
									</td>
									<td class="px-5 py-4 font-mono text-xs text-es-muted">
										<p>Internal: @InternalTcpEndpoint(member)</p>
										<p class="mt-1">External: @ExternalTcpEndpoint(member)</p>
									</td>
									<td class="px-5 py-4 font-mono text-xs text-es-muted">@HttpEndpoint(member)</td>
									<td class="px-5 py-4 text-right">
										<div class="flex flex-wrap justify-end gap-2">
											<a class="rounded-full border border-es-ink/10 px-3 py-1.5 text-xs font-bold text-es-ink hover:border-es-green hover:text-es-forest" href="@($"//{HttpEndpoint(member)}/ui?probe=ping")">Ping</a>
											<a class="rounded-full border border-es-ink/10 px-3 py-1.5 text-xs font-bold text-es-ink hover:border-es-green hover:text-es-forest" href="@($"//{HttpEndpoint(member)}/ui")">Open</a>
											<a class="rounded-full border border-es-ink/10 px-3 py-1.5 text-xs font-bold text-es-ink hover:border-es-green hover:text-es-forest" href="@($"//{HttpEndpoint(member)}/ui?probe=cluster")">Membership</a>
										</div>
									</td>
								</tr>
							}
						}
					</tbody>
				</table>
			</div>
		</div>

		<div class="grid gap-5">
			<details id="cluster-snapshot" class="overflow-hidden rounded-[1.5rem] border border-es-ink/10 bg-es-ink text-white">
				<summary class="cursor-pointer px-5 py-4 text-sm font-black uppercase tracking-[0.18em] text-white/70 hover:text-white">Snapshot</summary>
				<pre class="max-h-[28rem] overflow-auto border-t border-white/10 p-5 text-xs leading-5 text-white/80">@ClusterSnapshot</pre>
			</details>

			<div class="overflow-hidden rounded-[1.5rem] border border-es-ink/10 bg-white">
				<div class="flex items-center justify-between gap-3 border-b border-es-ink/10 px-5 py-4">
					<div>
						<p class="text-xs font-black uppercase tracking-[0.18em] text-es-green">Replica status</p>
						<p class="mt-1 text-sm text-es-muted">@ReplicaStatusLabel</p>
					</div>
				</div>
				<div class="overflow-x-auto">
					<table class="min-w-full text-left text-sm">
						<thead class="border-b border-es-ink/10 bg-es-ink/5 text-xs font-black uppercase tracking-[0.16em] text-es-muted">
							<tr>
								<th class="px-5 py-4">Replica endpoint</th>
								<th class="px-5 py-4 text-right">Sent</th>
								<th class="px-5 py-4 text-right">Received</th>
								<th class="px-5 py-4 text-right">Pending send</th>
								<th class="px-5 py-4 text-right">Pending receive</th>
								<th class="px-5 py-4 text-right">Queue</th>
								<th class="px-5 py-4 text-right">To catch up</th>
								<th class="px-5 py-4 text-right">Speed/s</th>
								<th class="px-5 py-4 text-right">ETA</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-es-ink/10">
							@if (!Replicas.Replicas.Any())
							{
								<tr>
									<td class="px-5 py-4 text-es-muted" colspan="9">@ReplicaStatusLabel</td>
								</tr>
							}
							else
							{
								foreach (var replica in Replicas.Replicas)
								{
									<tr class="bg-white/70 text-es-ink">
										<td class="px-5 py-4 font-mono text-xs text-es-muted">@replica.SubscriptionEndpoint</td>
										<td class="px-5 py-4 text-right font-mono text-es-ink">@replica.TotalBytesSentLabel</td>
										<td class="px-5 py-4 text-right font-mono text-es-ink">@replica.TotalBytesReceivedLabel</td>
										<td class="px-5 py-4 text-right font-mono text-es-ink">@replica.PendingSendBytesLabel</td>
										<td class="px-5 py-4 text-right font-mono text-es-ink">@replica.PendingReceivedBytesLabel</td>
										<td class="px-5 py-4 text-right font-mono text-es-ink">@replica.SendQueueSizeLabel</td>
										@if (!replica.IsCatchingUp)
										{
											<td class="px-5 py-4 text-right font-bold text-es-forest" colspan="3">Caught Up</td>
										}
										else
										{
											<td class="px-5 py-4 text-right font-mono text-es-ink">@replica.BytesToCatchUpLabel</td>
											<td class="px-5 py-4 text-right font-mono text-es-ink">@replica.ApproximateSpeedLabel</td>
											<td class="px-5 py-4 text-right font-mono text-es-ink">@replica.EstimatedTimeLabel</td>
										}
									</tr>
								}
							}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
</section>

<section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
	<MetricCard Label="Runtime queues" Value="@(Page?.QueueCountLabel ?? "-")" QueueMetric="queue-count" />
	<MetricCard Label="Busy queues" Value="@(Page?.BusyQueueCountLabel ?? "-")" Tone="muted" QueueMetric="busy-count" />
	<MetricCard Label="Total backlog" Value="@(Page?.TotalBacklogLabel ?? "-")" Tone="muted" QueueMetric="backlog" />
	<MetricCard Label="Items/s" Value="@(Page?.TotalRateLabel ?? "-")" QueueMetric="rate" />
</section>

<section class="mt-5 grid gap-5 xl:grid-cols-[1.4fr_0.6fr]">
	<div class="overflow-hidden rounded-[2rem] border border-white/80 bg-white/85 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
		<div class="flex flex-col gap-3 border-b border-es-ink/10 px-5 py-5 sm:flex-row sm:items-center sm:justify-between">
			<div>
				<p class="text-xs font-black uppercase tracking-[0.22em] text-es-green">Queue pressure</p>
				<h2 class="mt-2 text-3xl font-black tracking-tight text-es-ink">Live node workload</h2>
				<p class="mt-2 text-sm text-es-muted">Updates every second while this tab is visible.</p>
			</div>
			<div class="flex flex-wrap gap-2">
				<span class="rounded-full border border-es-green/20 bg-es-green/10 px-4 py-2 text-sm font-bold text-es-forest" data-queue-status>Connecting live stats...</span>
				<span class="rounded-full border border-es-ink/10 bg-white px-4 py-2 text-sm font-bold text-es-muted" data-queue-updated>Waiting for first update</span>
				<a class="rounded-full bg-es-ink px-4 py-2 text-sm font-bold text-white hover:bg-es-green hover:text-white" href="/ui/observability">Open full dashboard</a>
			</div>
		</div>
		<div class="grid gap-5 p-5 lg:grid-cols-[0.95fr_1.05fr]">
			<div class="rounded-[1.5rem] border border-es-ink/10 bg-es-ink p-5 text-white">
				<p class="text-xs font-black uppercase tracking-[0.22em] text-white/60">Throughput map</p>
				<div class="mt-5 grid gap-4" data-queue-pressure-list>
					@if (Page is null)
					{
						<p class="text-sm leading-6 text-white/70">Loading runtime statistics...</p>
					}
					else if (!Page.IsAvailable)
					{
						<p class="text-sm leading-6 text-white/70">@Page.Message</p>
					}
					else if (SpotlightQueues.Count == 0)
					{
						<p class="text-sm leading-6 text-white/70">No queue statistics are available yet.</p>
					}
					else
					{
						@foreach (var queue in SpotlightQueues)
						{
							<div>
								<div class="flex items-center justify-between gap-3 text-xs font-bold">
									<span class="truncate text-white/80">@queue.Name</span>
									<span class="font-mono text-white">@queue.AvgItemsPerSecondLabel/s</span>
								</div>
								<div class="mt-2 h-2 overflow-hidden rounded-full bg-white/10">
									<div class="h-full rounded-full bg-es-green" style="@PressureStyle(queue)"></div>
								</div>
							</div>
						}
					}
				</div>
			</div>

			<div class="overflow-hidden rounded-[1.5rem] border border-es-ink/10 bg-white">
				<div class="border-b border-es-ink/10 px-4 py-3">
					<p class="text-xs font-black uppercase tracking-[0.22em] text-es-green">Queue spotlight</p>
				</div>
				<div class="overflow-x-auto">
					<table class="min-w-full text-left text-sm">
						<thead class="border-b border-es-ink/10 bg-es-ink/5 text-xs font-black uppercase tracking-[0.16em] text-es-muted">
							<tr>
								<th class="px-4 py-3">Queue</th>
								<th class="px-4 py-3 text-right">Length</th>
								<th class="px-4 py-3 text-right">Rate</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-es-ink/10" data-queue-spotlight-body>
							@if (SpotlightQueues.Count == 0)
							{
								<tr>
									<td class="px-4 py-4 text-es-muted" colspan="3">Queue data is not available.</td>
								</tr>
							}
							else
							{
								foreach (var queue in SpotlightQueues.Take(6))
								{
									<tr class="bg-white/70">
										<td class="max-w-xs px-4 py-3">
											<p class="truncate font-bold text-es-ink">@queue.Name</p>
											<p class="mt-1 truncate text-xs text-es-muted">@queue.LastProcessedMessage</p>
										</td>
										<td class="px-4 py-3 text-right font-mono text-es-ink">@queue.LengthLabel</td>
										<td class="px-4 py-3 text-right font-mono text-es-ink">@queue.AvgItemsPerSecondLabel</td>
									</tr>
								}
							}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>

	<aside class="grid gap-5">
		<div class="rounded-[2rem] border border-white/80 bg-white/85 p-5 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
			<div class="flex items-center justify-between gap-3">
				<div>
					<p class="text-xs font-black uppercase tracking-[0.22em] text-es-green">Node probes</p>
					<h2 class="mt-2 text-2xl font-black tracking-tight text-es-ink">Quick checks</h2>
				</div>
			</div>
			<div class="mt-5 grid gap-2">
				@foreach (var probe in Probes)
				{
					<a class="@ProbeLinkClass(probe)" href="@($"/ui?probe={probe.Key}")">@probe.Title</a>
				}
			</div>
			@if (ProbeResult.HasProbe)
			{
				<div class="mt-4 overflow-hidden rounded-[1.5rem] border border-es-ink/10 bg-white shadow-inner shadow-es-ink/5">
					<div class="flex flex-wrap items-center justify-between gap-3 border-b border-es-ink/10 px-4 py-3">
						<div>
							<p class="text-xs font-black uppercase tracking-[0.2em] text-es-green">@ProbeResult.Probe.Title</p>
							<p class="mt-1 text-sm text-es-muted">@ProbeResult.Probe.Description</p>
						</div>
					</div>
					@if (ProbeResult.IsAvailable)
					{
						<pre class="max-h-72 overflow-auto bg-es-ink px-4 py-4 font-mono text-xs leading-5 text-white">@ProbeResult.Content</pre>
					}
					else
					{
						<p class="px-4 py-5 text-sm font-bold leading-6 text-es-muted">@ProbeResult.Message</p>
					}
				</div>
			}
		</div>

		<div class="rounded-[2rem] bg-es-green p-5 text-white shadow-[0_20px_70px_rgba(107,163,0,0.20)]">
			<p class="text-xs font-black uppercase tracking-[0.22em] text-white/70">Routine operations</p>
			<h2 class="mt-3 text-2xl font-black tracking-tight">One dashboard for routine operations.</h2>
			<p class="mt-3 text-sm leading-6 text-white/80">Live membership, workload, and follow-up actions stay together for daily node checks.</p>
		</div>
	</aside>
</section>

<section class="mt-5 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
	<SurfaceCard Eyebrow="Explore" Title="Navigator" Description="Jump into streams, subscriptions, projections, user management, and browser tools from one place." Href="/ui/navigator" LinkText="Open" />
	<SurfaceCard Eyebrow="Run" Title="Operations" Description="Reach privileged actions for scavenging, shutdown, reload, and node-level workflows." Href="/ui/operations" LinkText="Open" />
	<SurfaceCard Eyebrow="Watch" Title="Observability" Description="Inspect queues, replication, TCP, metrics, and health through a curated operator map." Href="/ui/observability" LinkText="Open" />
	<SurfaceCard Eyebrow="Review" Title="Configuration" Description="Find runtime information, loaded options, and subsystem metadata." Href="/ui/configuration" LinkText="Open" />
</section>
</div>

@code {
	private QueueDashboardPage Page { get; set; }
	private ClientClusterInfo ClusterInfo { get; set; }
	private ClusterReplicaPage Replicas { get; set; } = ClusterReplicaPage.Unavailable("No replica stats reported.");
	private string ClusterMessage { get; set; } = "";
	private DateTime? ClusterReadAt { get; set; }
	private NodeProbeRead ProbeResult { get; set; } = NodeProbeRead.Unselected();

	[SupplyParameterFromQuery(Name = "probe")]
	private string Probe { get; set; } = "";

	private static readonly IReadOnlyList<NodeProbeDefinition> Probes = NodeProbeService.Probes;

	private IReadOnlyList<ClientClusterInfo.ClientMemberInfo> ClusterMembers =>
		ClusterInfo?.Members ?? Array.Empty<ClientClusterInfo.ClientMemberInfo>();

	private bool ClusterAvailable => string.IsNullOrWhiteSpace(ClusterMessage) && ClusterMembers.Count > 0;

	private string ClusterStatusLabel => ClusterAvailable ? "Cluster loaded" : "Cluster unavailable";

	private string ClusterStatusBadgeClass => ClusterAvailable
		? "rounded-full border border-es-green/20 bg-es-green/10 px-4 py-2 text-sm font-bold text-es-forest"
		: "rounded-full border border-red-200 bg-red-50 px-4 py-2 text-sm font-bold text-red-700";

	private string ClusterUpdatedLabel => ClusterReadAt is null
		? "Not loaded"
		: $"Snapshot {ClusterReadAt.Value:HH:mm:ss} UTC";

	private string ReplicaStatusLabel => Replicas.StatusLabel;

	private string DashboardPayloadJson => Page?.ClientPayloadJson ?? "{}";

	private string ClusterEmptyMessage => string.IsNullOrWhiteSpace(ClusterMessage)
		? "No nodes in the cluster."
		: ClusterMessage;

	private string MemberCountLabel => ClusterMembers.Count.ToString(CultureInfo.InvariantCulture);

	private string AliveCountLabel => ClusterMembers.Count(x => x.IsAlive).ToString(CultureInfo.InvariantCulture);

	private string ReadOnlyCountLabel => ClusterMembers.Count(x => x.IsReadOnlyReplica).ToString(CultureInfo.InvariantCulture);

	private string LeaderLabel {
		get {
			var leader = ClusterMembers.FirstOrDefault(x => x.State == VNodeState.Leader);
			return leader is null ? "-" : HttpEndpoint(leader);
		}
	}

	private string ClusterSnapshot {
		get {
			if (!ClusterMembers.Any())
				return ClusterEmptyMessage;

			var builder = new StringBuilder()
				.Append("Snapshot taken at ")
				.Append(TimestampLabel(ClusterReadAt ?? DateTime.UtcNow))
				.AppendLine()
				.Append(PadRight("Internal Tcp", 31)).Append(' ')
				.Append(PadRight("External Tcp", 31)).Append(' ')
				.Append(PadRight("Http", 23)).Append(' ')
				.Append(PadRight("Status", 11)).Append(' ')
				.Append(PadRight("State", 18)).Append(' ')
				.Append(PadRight("Timestamp (UTC)", 19)).Append(" Checkpoints");

			foreach (var member in ClusterMembers)
			{
				builder.AppendLine()
					.Append(PadRight(InternalTcpEndpoint(member), 31)).Append(' ')
					.Append(PadRight(ExternalTcpEndpoint(member), 31)).Append(' ')
					.Append(PadRight(HttpEndpoint(member), 23)).Append(' ')
					.Append(PadRight(MemberStatus(member), 11)).Append(' ')
					.Append(PadRight(member.State.ToString(), 18)).Append(' ')
					.Append(PadRight(TimestampLabel(member.TimeStamp), 19)).Append(' ')
					.Append(CheckpointSnapshot(member));
			}

			return builder.ToString();
		}
	}

	private IReadOnlyList<QueueDashboardRow> SpotlightQueues =>
		Page?.Queues
			.Where(x => !x.IsGroupSummary)
			.OrderByDescending(x => x.LengthCurrentTryPeak + x.AvgItemsPerSecond)
			.ThenBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
			.Take(8)
			.ToArray() ?? Array.Empty<QueueDashboardRow>();

	private long MaxPressure =>
		Math.Max(1, SpotlightQueues.Select(x => x.LengthCurrentTryPeak + x.AvgItemsPerSecond).DefaultIfEmpty(1).Max());

	private NodeProbeDefinition SelectedProbe => NodeProbeService.Find(Probe);

	protected override async Task OnParametersSetAsync() {
		Page = null;
		ClusterInfo = null;
		Replicas = ClusterReplicaPage.Unavailable("No replica stats reported.");
		ClusterMessage = "";
		ClusterReadAt = null;
		ProbeResult = NodeProbeRead.Unselected();

		try
		{
			ClusterInfo = await ClusterStatus.Read();
			Replicas = await ClusterStatus.ReadReplicas(ClusterInfo);
			ClusterReadAt = DateTime.UtcNow;
		}
		catch (OperationCanceledException)
		{
			throw;
		}
		catch (UnauthorizedAccessException)
		{
			ClusterMessage = "Cluster membership access was denied.";
		}
		catch (TimeoutException)
		{
			ClusterMessage = "Timed out reading cluster membership.";
		}
		catch (Exception ex)
		{
			ClusterMessage = $"Failed to load cluster membership: {UiMessages.Friendly(ex)}";
		}

		try
		{
			Page = await QueueDashboard.Read();
		}
		catch (OperationCanceledException)
		{
			throw;
		}
		catch (Exception ex)
		{
			Page = QueueDashboardPage.Unavailable($"Failed to load queue statistics: {UiMessages.Friendly(ex)}");
		}

		await LoadProbe();
	}

	private async Task LoadProbe() {
		var selectedProbe = SelectedProbe;
		if (selectedProbe is null)
			return;

		try
		{
			ProbeResult = await NodeProbes.Read(selectedProbe.Key);
		}
		catch (OperationCanceledException)
		{
			throw;
		}
		catch (Exception ex)
		{
			ProbeResult = NodeProbeRead.Unavailable(selectedProbe, $"Failed to load probe: {UiMessages.Friendly(ex)}");
		}
	}

	private string PressureStyle(QueueDashboardRow queue) {
		var pressure = queue.LengthCurrentTryPeak + queue.AvgItemsPerSecond;
		var width = Math.Clamp(pressure * 100d / MaxPressure, 6d, 100d);
		return string.Format(CultureInfo.InvariantCulture, "width: {0:0.##}%", width);
	}

	private string ProbeLinkClass(NodeProbeDefinition probe) =>
		string.Equals(probe.Key, Probe, StringComparison.OrdinalIgnoreCase)
			? "rounded-2xl border border-es-green bg-es-green px-4 py-3 font-bold text-white shadow-lg shadow-es-green/20 hover:bg-es-forest hover:text-white focus:text-white"
			: "rounded-2xl border border-es-ink/10 bg-white px-4 py-3 font-bold text-es-ink hover:border-es-green hover:text-es-forest";

	private static string MemberRowClass(ClientClusterInfo.ClientMemberInfo member) =>
		member.IsAlive ? "bg-white/70 text-es-ink" : "bg-red-50 text-es-ink";

	private static string MemberStateClass(ClientClusterInfo.ClientMemberInfo member) =>
		member.State switch {
			VNodeState.Leader => "font-black text-es-ink",
			VNodeState.Manager => "font-bold text-es-muted",
			VNodeState.CatchingUp => "font-bold text-amber-700",
			_ => member.IsAlive ? "font-bold text-es-ink" : "font-bold text-red-700"
		};

	private static string MemberStatusClass(ClientClusterInfo.ClientMemberInfo member) =>
		member.IsAlive ? "px-5 py-4 font-bold text-es-forest" : "px-5 py-4 font-bold text-red-700";

	private static string MemberStatus(ClientClusterInfo.ClientMemberInfo member) =>
		member.IsAlive ? "Alive" : "Unreachable";

	private static string InternalTcpEndpoint(ClientClusterInfo.ClientMemberInfo member) =>
		Endpoint(
			member.InternalTcpIp,
			member.InternalSecureTcpPort != 0 ? member.InternalSecureTcpPort : member.InternalTcpPort);

	private static string ExternalTcpEndpoint(ClientClusterInfo.ClientMemberInfo member) =>
		Endpoint(
			member.ExternalTcpIp,
			member.ExternalSecureTcpPort != 0 ? member.ExternalSecureTcpPort : member.ExternalTcpPort);

	private static string HttpEndpoint(ClientClusterInfo.ClientMemberInfo member) =>
		Endpoint(member.HttpEndPointIp, member.HttpEndPointPort);

	private static string Endpoint(string host, int port) =>
		$"{(string.IsNullOrWhiteSpace(host) ? "<none>" : host)}:{port}";

	private static string TimestampLabel(DateTime timestamp) =>
		timestamp == default
			? "-"
			: timestamp.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture);

	private static string CheckpointLabel(ClientClusterInfo.ClientMemberInfo member) =>
		$"L{FormatInteger(member.LastCommitPosition)} / W {FormatInteger(member.WriterCheckpoint)} / C {FormatInteger(member.ChaserCheckpoint)}";

	private static string EpochLabel(ClientClusterInfo.ClientMemberInfo member) =>
		$"E{member.EpochNumber} @ {FormatInteger(member.EpochPosition)} : {{ {member.EpochId} }}";

	private static string CheckpointSnapshot(ClientClusterInfo.ClientMemberInfo member) =>
		member.State == VNodeState.Manager
			? "n/a"
			: $"L{member.LastCommitPosition}/W{member.WriterCheckpoint}/C{member.ChaserCheckpoint}/E{member.EpochNumber}@{member.EpochPosition}:{{{member.EpochId}}}";

	private static string FormatInteger(long value) =>
		value.ToString("N0", CultureInfo.InvariantCulture);

	private static string PadRight(string value, int width) {
		var text = Truncate(value ?? "", width);
		return text.PadRight(width);
	}

	private static string Truncate(string value, int width) =>
		value.Length > width ? value[..Math.Max(0, width - 3)] + "..." : value;
}
