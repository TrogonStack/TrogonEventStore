@page "/ui/streams/append"
@page "/ui/streams/append/{*StreamId}"
@using EventStore.ClusterNode.Components.Services
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@inject StreamBrowserService Streams

<PageTitle>Add Event - EventStore UI</PageTitle>

<section class="max-w-5xl">
	<a class="text-sm font-bold text-es-green transition hover:text-es-forest" href="@BackHref">&lt;- Back</a>
	<p class="mt-6 text-sm font-black uppercase tracking-[0.28em] text-es-green">New event</p>
	<h1 class="mt-4 text-5xl font-black tracking-tight text-es-ink sm:text-6xl">Append JSON to a stream.</h1>
	<p class="mt-5 text-lg leading-8 text-es-muted">Use the same event id, type, data, and metadata shape the legacy browser exposed, with validation before the write reaches the node.</p>
</section>

<section class="mt-8 grid gap-5 lg:grid-cols-[1.2fr_0.8fr]">
	<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
		<EditForm Model="Input" FormName="stream-append" OnValidSubmit="Append">
			<AntiforgeryToken />
			<DataAnnotationsValidator />

			<div class="grid gap-4 md:grid-cols-2">
				<label class="text-sm font-bold text-es-muted">
					Stream ID
					<InputText class="mt-2 w-full rounded-2xl border border-es-ink/10 bg-white px-4 py-3 font-mono text-sm text-es-ink outline-none transition focus:border-es-green focus:ring-4 focus:ring-es-green/15" @bind-Value="Input.StreamId" />
					<ValidationMessage For="() => Input.StreamId" />
				</label>
				<label class="text-sm font-bold text-es-muted">
					Event ID
					<InputText class="mt-2 w-full rounded-2xl border border-es-ink/10 bg-white px-4 py-3 font-mono text-sm text-es-ink outline-none transition focus:border-es-green focus:ring-4 focus:ring-es-green/15" @bind-Value="Input.EventId" />
					<ValidationMessage For="() => Input.EventId" />
				</label>
				<label class="md:col-span-2 text-sm font-bold text-es-muted">
					Event Type
					<InputText class="mt-2 w-full rounded-2xl border border-es-ink/10 bg-white px-4 py-3 font-mono text-sm text-es-ink outline-none transition focus:border-es-green focus:ring-4 focus:ring-es-green/15" @bind-Value="Input.EventType" />
					<ValidationMessage For="() => Input.EventType" />
				</label>
			</div>

			<label class="mt-5 block text-sm font-black uppercase tracking-[0.22em] text-es-green" for="eventData">Data</label>
			<InputTextArea id="eventData" class="mt-3 min-h-80 w-full rounded-2xl border border-es-ink/10 bg-es-ink px-4 py-3 font-mono text-sm text-white outline-none transition placeholder:text-white/40 focus:border-es-green focus:ring-4 focus:ring-es-green/15" @bind-Value="Input.Data" />
			<ValidationMessage For="() => Input.Data" />

			<label class="mt-5 block text-sm font-black uppercase tracking-[0.22em] text-es-green" for="eventMetadata">Metadata</label>
			<InputTextArea id="eventMetadata" class="mt-3 min-h-40 w-full rounded-2xl border border-es-ink/10 bg-es-ink px-4 py-3 font-mono text-sm text-white outline-none transition placeholder:text-white/40 focus:border-es-green focus:ring-4 focus:ring-es-green/15" @bind-Value="Input.Metadata" />

			@if (Result is not null)
			{
				<p class="mt-5 rounded-2xl border @(Result.Success ? "border-es-green/25 bg-es-green/10 text-es-forest" : "border-red-200 bg-red-50 text-red-800") p-4 text-sm font-bold">@Result.Message</p>
			}

			<div class="mt-5 flex flex-wrap gap-2">
				<button class="rounded-2xl bg-es-ink px-5 py-3 text-sm font-black text-white shadow-lg shadow-es-ink/15 transition hover:bg-es-green" type="submit">Add event</button>
				<a class="rounded-2xl border border-es-ink/10 bg-white px-5 py-3 text-sm font-black text-es-ink transition hover:border-es-green/30 hover:text-es-forest" href="@BackHref">Cancel</a>
			</div>
		</EditForm>
	</article>

	<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
		<StatusBadge Label="JSON event" Tone="good" />
		<h2 class="mt-4 text-2xl font-black tracking-tight text-es-ink">Append behavior</h2>
		<p class="mt-3 text-sm leading-6 text-es-muted">This keeps the legacy browser's append contract: one JSON event, optional JSON metadata, generated id by default, and no writes to system streams.</p>
		@if (FromEvent.HasValue)
		{
			<p class="mt-4 rounded-2xl border border-es-green/20 bg-es-green/10 p-4 text-sm font-bold text-es-forest">Prefilled from event #@FromEvent.Value.</p>
		}
	</article>
</section>

@code {
	[Parameter] public string StreamId { get; set; } = "";
	[SupplyParameterFromQuery] public long? FromEvent { get; set; }

	[SupplyParameterFromForm(FormName = "stream-append")]
	private StreamAppendInput Input { get; set; } = NewInput("");

	private StreamCommandResult Result { get; set; }
	private string BackHref => string.IsNullOrWhiteSpace(Input.StreamId)
		? "/ui/streams"
		: $"/ui/streams/{Uri.EscapeDataString(Input.StreamId)}";

	protected override async Task OnParametersSetAsync() {
		var requestedStream = StreamId ?? "";
		var hasSubmittedForm = !string.IsNullOrWhiteSpace(Input.StreamId) &&
			(string.IsNullOrWhiteSpace(requestedStream) || string.Equals(Input.StreamId, requestedStream, StringComparison.OrdinalIgnoreCase));
		if (hasSubmittedForm)
			return;

		Input = NewInput(requestedStream);
		Result = null;

		if (FromEvent.HasValue && !string.IsNullOrWhiteSpace(requestedStream)) {
			var page = await Streams.ReadEvent(requestedStream, FromEvent.Value);
			if (page.Event is not null) {
				Input.EventType = page.Event.EventType;
				Input.Data = page.Event.DataForDisplay;
				Input.Metadata = page.Event.MetadataForDisplay;
			}
		}
	}

	private async Task Append() {
		try {
			Result = await Streams.AppendEvent(new StreamAppendRequest(
				Input.StreamId,
				Input.EventId,
				Input.EventType,
				Input.Data,
				Input.Metadata));

			if (Result.Success)
				Input.EventId = Guid.NewGuid().ToString("D");
		} catch (OperationCanceledException) {
			Result = StreamCommandResult.Failure(Input.StreamId, "Event append was canceled.");
		} catch (Exception ex) {
			Result = StreamCommandResult.Failure(Input.StreamId, $"Failed to append event: {UserInterfaceMessages.Friendly(ex)}");
		}
	}

	private static StreamAppendInput NewInput(string streamId) => new() {
		StreamId = streamId,
		EventId = Guid.NewGuid().ToString("D"),
		Data = "{\n}",
		Metadata = "{\n}"
	};

	private sealed class StreamAppendInput {
		[Required(ErrorMessage = "Enter a stream id.")]
		public string StreamId { get; set; } = "";

		[Required(ErrorMessage = "Enter an event id.")]
		public string EventId { get; set; } = "";

		[Required(ErrorMessage = "Enter an event type.")]
		public string EventType { get; set; } = "";

		[Required(ErrorMessage = "Enter JSON event data.")]
		public string Data { get; set; } = "";

		public string Metadata { get; set; } = "";
	}
}
