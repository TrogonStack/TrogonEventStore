@page "/ui/subscriptions/new"
@inject SubscriptionBrowserService SubscriptionBrowser
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>New Subscription - EventStore UI</PageTitle>

<section class="max-w-5xl">
	<a class="text-sm font-bold text-es-green transition hover:text-es-forest" href="/ui/subscriptions">Back to subscriptions</a>
	<p class="mt-6 text-sm font-black uppercase tracking-[0.28em] text-es-green">New subscription</p>
	<h1 class="mt-4 text-5xl font-black tracking-tight text-es-ink sm:text-6xl">Create a persistent subscription.</h1>
	<p class="mt-5 text-lg leading-8 text-es-muted">Configure the same delivery controls exposed by the legacy persistent subscriptions page without leaving the Razor workspace.</p>
</section>

<section class="mt-8 grid gap-5 xl:grid-cols-[1.2fr_0.8fr]">
	<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
		<EditForm Model="Input" FormName="subscription-create" OnValidSubmit="CreateSubscription">
			<AntiforgeryToken />
			<DataAnnotationsValidator />
			<SubscriptionSettingsFields Model="Input" AllowIdentityEdit="true" />

			@if (Result is not null && !Result.Success)
			{
				<p class="mt-5 rounded-2xl border border-red-200 bg-red-50 p-4 text-sm font-bold text-red-800">@Result.Message</p>
			}

			<div class="mt-5 flex flex-wrap gap-2">
				<button class="rounded-2xl bg-es-ink px-5 py-3 text-sm font-black text-white shadow-lg shadow-es-ink/15 transition hover:bg-es-green" type="submit">Create subscription</button>
				<a class="rounded-2xl border border-es-ink/10 bg-white px-5 py-3 text-sm font-black text-es-ink transition hover:border-es-green/30 hover:text-es-forest" href="/ui/subscriptions">Cancel</a>
			</div>
		</EditForm>
	</article>

	<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
		<StatusBadge Label="Consumer pressure" Tone="warn" />
		<h2 class="mt-4 text-2xl font-black tracking-tight text-es-ink">Defaults match the legacy page</h2>
		<p class="mt-3 text-sm leading-6 text-es-muted">The initial values preserve the old UI defaults: round-robin delivery, 500-item buffers, 20-event read batches, and checkpointing every 1,000 ms.</p>
	</article>
</section>

@code {
	[SupplyParameterFromForm(FormName = "subscription-create")]
	private SubscriptionSettingsInput Input { get; set; } = new();

	private SubscriptionCommandResult Result { get; set; }

	private async Task CreateSubscription() {
		var redirectTo = "";
		try {
			Result = await SubscriptionBrowser.Create(Input.ToRequest());
			if (Result.Success)
				redirectTo = $"/ui/subscriptions/{Uri.EscapeDataString(Result.StreamId)}/{Uri.EscapeDataString(Result.GroupName)}";
		} catch (OperationCanceledException) {
			Result = SubscriptionCommandResult.Failure(Input.StreamId, Input.GroupName, "Subscription creation was canceled.");
		} catch (Exception ex) {
			Result = SubscriptionCommandResult.Failure(Input.StreamId, Input.GroupName, $"Failed to create subscription: {FriendlyMessage(ex)}");
		}

		if (!string.IsNullOrWhiteSpace(redirectTo))
			Navigation.NavigateTo(redirectTo);
	}

	private static string FriendlyMessage(Exception ex) =>
		string.IsNullOrWhiteSpace(ex.Message) ? ex.GetType().Name : ex.Message;
}
