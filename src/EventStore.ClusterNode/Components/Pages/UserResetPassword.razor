@page "/ui/users/{LoginName}/reset"
@inject UserBrowserService UserBrowser
@inject NavigationManager Navigation
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Reset User Password - EventStore UI</PageTitle>

<section class="max-w-5xl">
	<a class="text-sm font-bold text-es-green transition hover:text-es-forest" href="@($"/ui/users/{Uri.EscapeDataString(LoginName)}")">Back to user</a>
	<p class="mt-6 text-sm font-black uppercase tracking-[0.28em] text-es-green">Reset password</p>
	<h1 class="mt-4 break-words text-5xl font-black tracking-tight text-es-ink sm:text-6xl">@LoginName</h1>
	<p class="mt-5 text-lg leading-8 text-es-muted">Set a new password for this internal user. The current browser credentials are not rewritten automatically, so operators can choose when to sign in again.</p>
</section>

@if (Page is null)
{
	<section class="mt-8 rounded-[2rem] border border-white/80 bg-white/80 p-6 text-es-muted shadow-[0_18px_60px_rgba(23,32,51,0.08)]">
		Loading user...
	</section>
}
else if (Page.User is null)
{
	<section class="mt-8 rounded-[2rem] border border-white/80 bg-white/80 p-6 text-es-muted shadow-[0_18px_60px_rgba(23,32,51,0.08)]">
		@Page.Message
	</section>
}
else
{
	<section class="mt-8 grid gap-5 lg:grid-cols-[1.1fr_0.9fr]">
		<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
			<EditForm Model="Input" FormName="user-reset-password" OnValidSubmit="ResetPassword">
				<AntiforgeryToken />
				<DataAnnotationsValidator />
				<InputText type="hidden" @bind-Value="Input.LoginName" />

				<div class="grid gap-4 md:grid-cols-2">
					<label class="text-sm font-bold text-es-muted">
						New password
						<InputText type="password" class="mt-2 w-full rounded-2xl border border-es-ink/10 bg-white px-4 py-3 text-es-ink outline-none transition focus:border-es-green focus:ring-4 focus:ring-es-green/15" @bind-Value="Input.Password" />
						<ValidationMessage For="() => Input.Password" />
					</label>
					<label class="text-sm font-bold text-es-muted">
						Confirm password
						<InputText type="password" class="mt-2 w-full rounded-2xl border border-es-ink/10 bg-white px-4 py-3 text-es-ink outline-none transition focus:border-es-green focus:ring-4 focus:ring-es-green/15" @bind-Value="Input.ConfirmPassword" />
						<ValidationMessage For="() => Input.ConfirmPassword" />
					</label>
				</div>

				@if (Result is not null)
				{
					<p class="mt-5 rounded-2xl border @(Result.Success ? "border-es-green/25 bg-es-green/10 text-es-forest" : "border-red-200 bg-red-50 text-red-800") p-4 text-sm font-bold">@Result.Message</p>
				}

				<div class="mt-5 flex flex-wrap gap-2">
					<button class="rounded-2xl bg-es-ink px-5 py-3 text-sm font-black text-white shadow-lg shadow-es-ink/15 transition hover:bg-es-green" type="submit">Reset password</button>
					<a class="rounded-2xl border border-es-ink/10 bg-white px-5 py-3 text-sm font-black text-es-ink transition hover:border-es-green/30 hover:text-es-forest" href="@Page.User.DetailHref">Cancel</a>
				</div>
			</EditForm>
		</article>

		<article class="rounded-[2rem] border border-amber-200 bg-amber-50 p-6 text-amber-950 shadow-[0_20px_70px_rgba(146,64,14,0.08)]">
			<StatusBadge Label="Credential change" Tone="warn" />
			<h2 class="mt-4 text-2xl font-black tracking-tight">Session reminder</h2>
			<p class="mt-3 text-sm leading-6">The legacy UI tried to rewrite the basic-auth cookie after a reset. This page leaves the session untouched so failed cookie rewrites cannot hide a successful server-side password change.</p>
		</article>
	</section>
}

@code {
	[Parameter] public string LoginName { get; set; } = "";

	[SupplyParameterFromForm(FormName = "user-reset-password")]
	private UserPasswordInput Input { get; set; } = new();

	private UserDetailPage Page { get; set; }
	private UserCommandResult Result { get; set; }

	protected override async Task OnParametersSetAsync() {
		var requested = LoginName;
		var hasSubmittedForm = string.Equals(Input.LoginName, requested, StringComparison.OrdinalIgnoreCase);
		Page = null;
		Result = null;
		if (!hasSubmittedForm)
			Input = new();

		try {
			var page = await UserBrowser.Read(requested);
			if (requested != LoginName)
				return;

			Page = page;
			if (Page.User is not null)
				Input.LoginName = Page.User.LoginName;
		} catch (OperationCanceledException) {
			throw;
		} catch (Exception ex) {
			if (requested == LoginName)
				Page = UserDetailPage.Unavailable(requested, UserBrowser.ReadCurrentRequest(), $"Failed to load user: {UserInterfaceMessages.Friendly(ex)}");
		}
	}

	private async Task ResetPassword() {
		if (Page?.User is not { } user) {
			Result = UserCommandResult.Failure(LoginName, "User details are not loaded.");
			return;
		}

		var loginName = user.LoginName;
		var redirectTo = "";
		try {
			Result = await UserBrowser.ResetPassword(new UserPasswordResetRequest(loginName, Input.Password, Input.ConfirmPassword));
			if (Result.Success)
				redirectTo = $"/ui/users/{Uri.EscapeDataString(Result.LoginName)}";
		} catch (OperationCanceledException) {
			Result = UserCommandResult.Failure(loginName, "Password reset was canceled.");
		} catch (Exception ex) {
			Result = UserCommandResult.Failure(loginName, $"Failed to reset password: {UserInterfaceMessages.Friendly(ex)}");
		}

		if (!string.IsNullOrWhiteSpace(redirectTo))
			Navigation.NavigateTo(redirectTo);
	}

	private sealed class UserPasswordInput {
		public string LoginName { get; set; } = "";

		[Required(ErrorMessage = "Enter a new password.")]
		public string Password { get; set; } = "";

		[Compare(nameof(Password), ErrorMessage = "The password confirmation does not match.")]
		public string ConfirmPassword { get; set; } = "";
	}
}
