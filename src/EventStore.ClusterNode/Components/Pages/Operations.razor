@page "/ui/operations"
@inject AdminOperationsService AdminOps

<PageTitle>Operations - EventStore UI</PageTitle>

<section class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start" data-admin-auto-refresh="2000">
	<div>
		<p class="text-sm font-black uppercase tracking-[0.28em] text-es-green">Operations</p>
		<h1 class="mt-4 text-5xl font-black tracking-tight text-es-ink sm:text-6xl">Admin workflows without leaving the workspace.</h1>
		<p class="mt-5 text-lg leading-8 text-es-muted">Manage subsystems, scavenges, and privileged node commands from the Razor shell while keeping destructive actions visibly isolated.</p>
	</div>
	<div class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
		<p class="text-sm font-black uppercase tracking-[0.22em] text-es-green">Command status</p>
		<p class="mt-3 leading-7 text-es-muted">Actions run as the current operator and report back in-place, so the page stays anchored after a command.</p>
		<div hidden data-admin-command-status class="mt-5 rounded-2xl border border-es-ink/10 bg-es-ink/5 px-4 py-3 text-sm font-bold text-es-ink"></div>
	</div>
</section>

@if (Page is null)
{
	<section class="mt-8 rounded-[2rem] border border-white/80 bg-white/80 p-6 text-es-muted shadow-[0_18px_60px_rgba(23,32,51,0.08)]">
		Loading operations...
	</section>
}
else
{
	<section class="mt-8 grid gap-5 xl:grid-cols-[0.85fr_1.15fr]">
		<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
			<div class="flex flex-wrap items-center justify-between gap-3">
				<div>
					<p class="text-sm font-black uppercase tracking-[0.22em] text-es-green">Enabled sub systems</p>
					<h2 class="mt-2 text-2xl font-black tracking-tight text-es-ink">Node capabilities</h2>
				</div>
				<StatusBadge Label="Read-only" Tone="muted" />
			</div>

			@if (!Page.Subsystems.IsAvailable)
			{
				<p class="mt-5 rounded-2xl border border-red-200 bg-red-50 p-4 text-sm font-bold text-red-800">@Page.Subsystems.Message</p>
			}
			else if (!Page.Subsystems.HasSubsystems)
			{
				<p class="mt-5 rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4 text-sm font-bold text-es-muted">No optional subsystems are enabled.</p>
			}
			else
			{
				<div class="mt-5 overflow-hidden rounded-2xl border border-es-ink/10">
					<table class="min-w-full divide-y divide-es-ink/10 text-sm">
						<thead class="bg-es-ink/5 text-left text-xs font-black uppercase tracking-[0.18em] text-es-muted">
							<tr>
								<th class="px-4 py-3">Subsystem</th>
								<th class="px-4 py-3">Status</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-es-ink/10 bg-white/70">
							@foreach (var subsystem in Page.Subsystems.Subsystems)
							{
								<tr>
									<td class="px-4 py-3 font-bold text-es-ink">@subsystem.Name</td>
									<td class="px-4 py-3"><StatusBadge Label="@subsystem.Status" Tone="good" /></td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			}

			<div class="mt-5 flex flex-wrap gap-2">
				<a class="rounded-full border border-es-ink/10 bg-white px-4 py-2 text-sm font-bold text-es-ink transition hover:border-es-green/30 hover:text-es-forest" href="/ui/configuration">Configuration</a>
			</div>
		</article>

		<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
			<div class="flex flex-wrap items-center justify-between gap-3">
				<div>
					<p class="text-sm font-black uppercase tracking-[0.22em] text-es-green">Scavenge</p>
					<h2 class="mt-2 text-2xl font-black tracking-tight text-es-ink">Database compaction</h2>
				</div>
				<StatusBadge Label="Privileged" Tone="warn" />
			</div>

			@if (!Page.Scavenge.SupportsScavenge)
			{
				<p class="mt-5 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-sm font-bold text-amber-900">@Page.Scavenge.SupportMessage</p>
			}

			<form class="mt-5 grid gap-4 rounded-[1.5rem] border border-es-ink/10 bg-white/70 p-5 md:grid-cols-5" method="post" action="/ui/operations/scavenge/start" data-admin-command data-confirm="Start a database scavenge?">
				<label class="text-sm font-bold text-es-muted">
					Start chunk
					<input class="mt-2 w-full rounded-2xl border border-es-ink/10 bg-white px-3 py-2 text-es-ink outline-none focus:border-es-green focus:ring-4 focus:ring-es-green/15" name="startFromChunk" type="number" min="0" value="0" disabled="@(!Page.Scavenge.SupportsScavenge)" />
				</label>
				<label class="text-sm font-bold text-es-muted">
					Threads
					<input class="mt-2 w-full rounded-2xl border border-es-ink/10 bg-white px-3 py-2 text-es-ink outline-none focus:border-es-green focus:ring-4 focus:ring-es-green/15" name="threads" type="number" min="1" value="1" disabled="@(!Page.Scavenge.SupportsScavenge)" />
				</label>
				<label class="text-sm font-bold text-es-muted">
					Threshold
					<input class="mt-2 w-full rounded-2xl border border-es-ink/10 bg-white px-3 py-2 text-es-ink outline-none focus:border-es-green focus:ring-4 focus:ring-es-green/15" name="threshold" type="number" disabled="@(!Page.Scavenge.SupportsScavenge)" />
				</label>
				<label class="text-sm font-bold text-es-muted">
					Throttle %
					<input class="mt-2 w-full rounded-2xl border border-es-ink/10 bg-white px-3 py-2 text-es-ink outline-none focus:border-es-green focus:ring-4 focus:ring-es-green/15" name="throttlePercent" type="number" min="1" max="100" disabled="@(!Page.Scavenge.SupportsScavenge)" />
				</label>
				<div class="flex flex-col justify-end gap-3">
					<label class="inline-flex items-center gap-2 text-sm font-bold text-es-muted">
						<input class="rounded border-es-ink/20 text-es-green focus:ring-es-green" name="syncOnly" type="checkbox" disabled="@(!Page.Scavenge.SupportsScavenge)" />
						Sync only
					</label>
					<button class="rounded-2xl bg-es-ink px-4 py-3 text-sm font-black text-white shadow-lg shadow-es-ink/15 transition hover:bg-es-green disabled:cursor-not-allowed disabled:bg-es-muted" type="submit" disabled="@(!Page.Scavenge.SupportsScavenge)">Start</button>
				</div>
			</form>

			<div class="mt-5 grid gap-4 md:grid-cols-2">
				<ScavengeStatusCard Title="Current scavenge" Status="@Page.Scavenge.Current" />
				<ScavengeStatusCard Title="Last scavenge" Status="@Page.Scavenge.Last" />
			</div>

			@if (!string.IsNullOrWhiteSpace(Page.Scavenge.HistoryMessage))
			{
				<p class="mt-5 rounded-2xl border border-red-200 bg-red-50 p-4 text-sm font-bold text-red-800">@Page.Scavenge.HistoryMessage</p>
			}
			else if (!Page.Scavenge.HasHistory)
			{
				<p class="mt-5 rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4 text-sm font-bold text-es-muted">No scavenge history is visible yet.</p>
			}
			else
			{
				<div class="mt-5 overflow-x-auto rounded-2xl border border-es-ink/10">
					<table class="min-w-full divide-y divide-es-ink/10 text-sm">
						<thead class="bg-es-ink/5 text-left text-xs font-black uppercase tracking-[0.18em] text-es-muted">
							<tr>
								<th class="px-4 py-3">Scavenge</th>
								<th class="px-4 py-3">Started</th>
								<th class="px-4 py-3">Completed</th>
								<th class="px-4 py-3">Result</th>
								<th class="px-4 py-3">Actions</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-es-ink/10 bg-white/70">
							@foreach (var item in Page.Scavenge.History)
							{
								<tr>
									<td class="px-4 py-3">
										<a class="font-mono text-sm font-bold text-es-forest hover:text-es-green" href="@item.DetailHref">@item.ScavengeId</a>
										@if (!string.IsNullOrWhiteSpace(item.NodeEndpoint))
										{
											<div class="mt-1 text-xs text-es-muted">@item.NodeEndpoint</div>
										}
									</td>
									<td class="px-4 py-3 font-mono text-xs text-es-muted">@item.StartedLabel</td>
									<td class="px-4 py-3 font-mono text-xs text-es-muted">@item.CompletedLabel</td>
									<td class="px-4 py-3">
										<StatusBadge Label="@item.ResultLabel" Tone="@item.Tone" />
										@if (!string.IsNullOrWhiteSpace(item.Error))
										{
											<div class="mt-2 max-w-xs text-xs leading-5 text-red-700">@item.Error</div>
										}
									</td>
									<td class="px-4 py-3">
										<div class="flex flex-wrap gap-2">
											<a class="rounded-full border border-es-ink/10 bg-white px-3 py-1.5 text-xs font-black text-es-ink transition hover:border-es-green/30 hover:text-es-forest" href="@item.DetailHref">Details</a>
											@if (item.CanStop)
											{
												<form method="post" action="/ui/operations/scavenge/stop" data-admin-command data-confirm="Stop this scavenge?">
													<input name="scavengeId" type="hidden" value="@item.ScavengeId" />
													<button class="rounded-full border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-black text-red-800 transition hover:bg-red-100" type="submit">Stop</button>
												</form>
											}
										</div>
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			}

			<p class="mt-5 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-sm leading-6 text-amber-900">If scavenge progress stops updating, the status stream may not be writable. Check the node logs before assuming the job is idle.</p>
			<div class="mt-5 flex flex-wrap gap-2">
				<a class="rounded-full border border-es-ink/10 bg-white px-4 py-2 text-sm font-bold text-es-ink transition hover:border-es-green/30 hover:text-es-forest" href="/ui/streams/$scavenges">Scavenge history stream</a>
			</div>
		</article>
	</section>

	<section class="mt-5 grid gap-5 lg:grid-cols-4">
		<NodeCommandCard Title="Reload configuration" Description="Refresh runtime configuration without restarting the process." Action="/ui/operations/reload-config" ButtonText="Reload" Confirm="Reload node configuration?" />
		<NodeCommandCard Title="Merge indexes" Description="Ask the node to start a manual index merge." Action="/ui/operations/merge-indexes" ButtonText="Merge" Confirm="Start a manual index merge?" />
		<NodeCommandCard Title="Resign leader" Description="Move leadership away from this node when cluster operations require it." Action="/ui/operations/resign" ButtonText="Resign" Confirm="Ask this node to resign leadership?" />
		<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
			<p class="text-sm font-black uppercase tracking-[0.22em] text-es-green">Node priority</p>
			<p class="mt-3 text-sm leading-6 text-es-muted">Adjust election priority deliberately during operations work.</p>
			<form class="mt-5 flex gap-2" method="post" action="/ui/operations/set-priority" data-admin-command data-confirm="Set node priority?">
				<input class="min-w-0 flex-1 rounded-2xl border border-es-ink/10 bg-white px-3 py-2 text-es-ink outline-none focus:border-es-green focus:ring-4 focus:ring-es-green/15" name="priority" type="number" value="0" />
				<button class="rounded-2xl bg-es-ink px-4 py-2 text-sm font-black text-white transition hover:bg-es-green" type="submit">Set</button>
			</form>
		</article>
	</section>

	<section class="mt-5 rounded-[2rem] border border-red-200 bg-red-50 p-6 text-red-950 shadow-[0_20px_70px_rgba(153,27,27,0.08)]">
		<div class="flex flex-wrap items-start justify-between gap-4">
			<div>
				<p class="text-sm font-black uppercase tracking-[0.22em] text-red-700">Destructive</p>
				<h2 class="mt-2 text-2xl font-black tracking-tight">Shutdown node</h2>
				<p class="mt-3 max-w-3xl text-sm leading-6">This requests process shutdown and should only be used when the operator intends to stop the node.</p>
			</div>
			<form method="post" action="/ui/operations/shutdown" data-admin-command data-admin-no-refresh="true" data-confirm="Shutdown this node?">
				<button class="rounded-2xl bg-red-700 px-5 py-3 text-sm font-black text-white shadow-lg shadow-red-900/15 transition hover:bg-red-800" type="submit">Shutdown</button>
			</form>
		</div>
	</section>
}

@code {
	private AdminOperationsPage Page { get; set; }

	protected override async Task OnInitializedAsync() {
		try {
			Page = await AdminOps.Read();
		} catch (OperationCanceledException) {
			Page = new AdminOperationsPage(
				SubsystemsPanel.Unavailable("Loading operations was canceled."),
				new ScavengeOperationsPanel(false, "Loading operations was canceled.", ScavengeStatusView.Unavailable("Canceled."), ScavengeStatusView.Unavailable("Canceled."), Array.Empty<ScavengeHistoryItem>(), "Canceled."));
		} catch (Exception ex) {
			var message = UiMessages.Friendly(ex);
			Page = new AdminOperationsPage(
				SubsystemsPanel.Unavailable($"Failed to load subsystems: {message}"),
				new ScavengeOperationsPanel(false, $"Failed to load scavenge support: {message}", ScavengeStatusView.Unavailable(message), ScavengeStatusView.Unavailable(message), Array.Empty<ScavengeHistoryItem>(), message));
		}
	}
}
