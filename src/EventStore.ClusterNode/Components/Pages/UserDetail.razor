@page "/ui/users/{LoginName}"
@inject UserBrowserService UserBrowser

<PageTitle>User - EventStore UI</PageTitle>

<section class="max-w-5xl">
	<a class="text-sm font-bold text-es-green transition hover:text-es-forest" href="/ui/users">Back to users</a>
	<p class="mt-6 text-sm font-black uppercase tracking-[0.28em] text-es-green">User detail</p>
	<h1 class="mt-4 break-words text-5xl font-black tracking-tight text-es-ink sm:text-6xl">@(Page?.User?.DisplayName ?? LoginName)</h1>
	<p class="mt-5 text-lg leading-8 text-es-muted">Review account metadata, update role membership, reset credentials, or disable access from explicit confirmation flows.</p>
</section>

<section class="mt-8 grid gap-5 lg:grid-cols-[0.8fr_1.2fr]">
	<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
		<div class="flex flex-wrap items-center gap-2">
			<StatusBadge Label="@(Page?.CurrentUser.AuthenticationLabel ?? "Loading")" Tone="@(Page?.CurrentUser.AuthenticationTone ?? "muted")" />
			<StatusBadge Label="Current request" Tone="muted" />
		</div>
		<h2 class="mt-4 text-3xl font-black tracking-tight text-es-ink">@(Page?.CurrentUser.NameLabel ?? "Loading user")</h2>
		<p class="mt-3 break-words text-sm text-es-muted">@(Page?.CurrentUser.RolesLabel ?? "Loading roles")</p>
	</article>

	@if (Page is null)
	{
		<div class="rounded-[2rem] border border-white/80 bg-white/80 p-6 text-es-muted shadow-[0_18px_60px_rgba(23,32,51,0.08)]">
			Loading user...
		</div>
	}
	else if (Page.User is null)
	{
		<div class="rounded-[2rem] border border-white/80 bg-white/80 p-6 text-es-muted shadow-[0_18px_60px_rgba(23,32,51,0.08)]">
			@Page.Message
		</div>
	}
	else
	{
		var user = Page.User;
		<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
			<div class="flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
				<div class="min-w-0">
					<StatusBadge Label="@user.StatusLabel" Tone="@user.StatusTone" />
					<h2 class="mt-4 break-words text-3xl font-black tracking-tight text-es-ink">@user.DisplayName</h2>
					<p class="mt-2 break-words font-mono text-sm text-es-muted">@user.LoginName</p>
				</div>
				<div class="flex flex-wrap gap-2">
					<a class="rounded-full bg-es-ink px-4 py-2 text-sm font-bold text-white transition hover:bg-es-green" href="@user.EditHref">Edit</a>
					<a class="rounded-full border border-es-ink/10 bg-white px-4 py-2 text-sm font-bold text-es-ink transition hover:border-es-green/30 hover:text-es-forest" href="@user.ResetPasswordHref">Reset password</a>
					<a class="rounded-full border border-es-ink/10 bg-white px-4 py-2 text-sm font-bold text-es-ink transition hover:border-es-green/30 hover:text-es-forest" href="@user.RawHref" target="_blank" rel="noopener noreferrer">Raw user</a>
					@if (user.Disabled)
					{
						<a class="rounded-full border border-es-green/30 bg-es-green/10 px-4 py-2 text-sm font-bold text-es-forest transition hover:bg-es-green hover:text-white" href="@user.EnableHref">Enable</a>
					}
					else
					{
						<a class="rounded-full border border-amber-200 bg-amber-50 px-4 py-2 text-sm font-bold text-amber-900 transition hover:bg-amber-100" href="@user.DisableHref">Disable</a>
					}
					<a class="rounded-full border border-red-200 bg-red-50 px-4 py-2 text-sm font-bold text-red-800 transition hover:bg-red-100" href="@user.DeleteHref">Delete</a>
				</div>
			</div>

			<div class="mt-6 grid gap-4 md:grid-cols-2">
				<div class="rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4">
					<p class="text-xs font-black uppercase tracking-[0.18em] text-es-muted">Full name</p>
					<p class="mt-2 break-words text-es-ink">@(string.IsNullOrWhiteSpace(user.FullName) ? "Not set" : user.FullName)</p>
				</div>
				<div class="rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4">
					<p class="text-xs font-black uppercase tracking-[0.18em] text-es-muted">Last updated</p>
					<p class="mt-2 font-mono text-sm text-es-ink">@user.UpdatedLabel</p>
				</div>
				<div class="rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4 md:col-span-2">
					<p class="text-xs font-black uppercase tracking-[0.18em] text-es-muted">Groups</p>
					<p class="mt-2 break-words text-es-ink">@user.GroupsLabel</p>
				</div>
			</div>

			<div class="mt-6 rounded-2xl border border-es-ink/10 bg-white/70 p-4">
				<p class="text-xs font-black uppercase tracking-[0.18em] text-es-muted">API links</p>
				<div class="mt-3 grid gap-2">
					@foreach (var link in user.ApiLinks)
					{
						@if (link.IsGet)
						{
							<a class="break-all rounded-2xl border border-es-ink/10 bg-es-ink/5 px-3 py-2 font-mono text-xs font-bold text-es-ink transition hover:border-es-green/30 hover:text-es-forest" href="@link.Href" target="_blank" rel="noopener noreferrer">@link.Method @link.Rel: @link.Href</a>
						}
						else
						{
							<div class="break-all rounded-2xl border border-es-ink/10 bg-es-ink/5 px-3 py-2 font-mono text-xs font-bold text-es-muted">
								<span class="mr-2 rounded-full bg-es-ink px-2 py-1 text-[0.65rem] uppercase tracking-[0.18em] text-white">@link.Method</span>
								@link.Rel: @link.Href
							</div>
						}
					}
				</div>
			</div>
		</article>
	}
</section>

@code {
	[Parameter] public string LoginName { get; set; } = "";

	private UserDetailPage Page { get; set; }

	protected override async Task OnParametersSetAsync() {
		var requested = LoginName;
		Page = null;

		try {
			var page = await UserBrowser.Read(requested);
			if (requested == LoginName)
				Page = page;
		} catch (OperationCanceledException) {
			throw;
		} catch (Exception ex) {
			if (requested == LoginName) {
				Page = UserDetailPage.Unavailable(requested, UserBrowser.ReadCurrentRequest(), $"Failed to load user: {UserInterfaceMessages.Friendly(ex)}");
			}
		}
	}
}
