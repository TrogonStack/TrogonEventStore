@page "/ui/subscriptions/{StreamId}/{GroupName}"
@inject SubscriptionBrowserService SubscriptionBrowser
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Subscription Detail - EventStore UI</PageTitle>

<section class="max-w-5xl">
	<a class="text-sm font-bold text-es-green transition hover:text-es-forest" href="/ui/subscriptions">Back to subscriptions</a>
	<p class="mt-6 text-sm font-black uppercase tracking-[0.28em] text-es-green">Persistent subscription</p>
	<h1 class="mt-4 break-words text-5xl font-black tracking-tight text-es-ink sm:text-6xl">@GroupName</h1>
	<p class="mt-5 break-words text-lg leading-8 text-es-muted">@StreamId</p>
</section>

@if (Page is null)
{
	<section class="mt-8 rounded-[2rem] border border-white/80 bg-white/80 p-6 text-es-muted shadow-[0_18px_60px_rgba(23,32,51,0.08)]">
		Loading subscription...
	</section>
}
else if (!Page.HasSubscription)
{
	<section class="mt-8 rounded-[2rem] border border-white/80 bg-white/80 p-6 text-es-muted shadow-[0_18px_60px_rgba(23,32,51,0.08)]">
		@Page.Message
	</section>
}
else
{
	var subscription = Page.Subscription;
	var behindLabel = subscription.BehindStatusLabel;
	var hasBehind = !string.IsNullOrWhiteSpace(behindLabel);
	var behindTone = subscription.BehindByMessages.GetValueOrDefault() > 0 ? "warn" : "muted";
	<section class="mt-8 grid gap-5 xl:grid-cols-[1fr_0.8fr]">
		<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
			<div class="flex flex-wrap items-center gap-2">
				<StatusBadge Label="@subscription.StatusLabel" Tone="@subscription.StatusTone" />
				<StatusBadge Label="@subscription.ConnectionLabel" Tone="muted" />
			</div>
			<h2 class="mt-4 break-words text-3xl font-black tracking-tight text-es-ink">@subscription.GroupName</h2>
			<p class="mt-2 break-words font-mono text-sm text-es-muted">@subscription.StreamId</p>

			<div class="mt-6 grid gap-3 md:grid-cols-2">
				<MetricCard Label="Parked" Value="@subscription.ParkedMessageCount.ToString()" Tone="bad" />
				<MetricCard Label="In flight" Value="@subscription.TotalInFlightMessages.ToString()" Tone="muted" />
				<MetricCard Label="Throughput" Value="@($"{subscription.AveragePerSecond}/s")" />
				<MetricCard Label="Behind / catch-up" Value="@(hasBehind ? behindLabel : "-")" Tone="@behindTone" />
			</div>

			<div class="mt-6 grid gap-3 text-sm md:grid-cols-2">
				<div class="rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4">
					<p class="text-xs font-black uppercase tracking-[0.18em] text-es-muted">Checkpoint</p>
					<p class="mt-2 break-words font-mono text-es-ink">@(string.IsNullOrWhiteSpace(subscription.LastCheckpointedEventPosition) ? "No checkpoint" : subscription.LastCheckpointedEventPosition)</p>
				</div>
				<div class="rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4">
					<p class="text-xs font-black uppercase tracking-[0.18em] text-es-muted">Known position</p>
					<p class="mt-2 break-words font-mono text-es-ink">@(string.IsNullOrWhiteSpace(subscription.LastKnownEventPosition) ? "Unknown" : subscription.LastKnownEventPosition)</p>
				</div>
				<div class="rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4">
					<p class="text-xs font-black uppercase tracking-[0.18em] text-es-muted">Strategy</p>
					<p class="mt-2 text-es-ink">@(string.IsNullOrWhiteSpace(subscription.NamedConsumerStrategy) ? "Unknown" : subscription.NamedConsumerStrategy)</p>
				</div>
				<div class="rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4">
					<p class="text-xs font-black uppercase tracking-[0.18em] text-es-muted">Start from</p>
					<p class="mt-2 font-mono text-es-ink">@(string.IsNullOrWhiteSpace(subscription.StartFrom) ? "Default" : subscription.StartFrom)</p>
				</div>
				<div class="rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4">
					<p class="text-xs font-black uppercase tracking-[0.18em] text-es-muted">Retry policy</p>
					<p class="mt-2 font-mono text-es-ink">@subscription.MaxRetryCount retries / @subscription.MessageTimeoutMilliseconds ms</p>
				</div>
				<div class="rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4">
					<p class="text-xs font-black uppercase tracking-[0.18em] text-es-muted">Buffers</p>
					<p class="mt-2 font-mono text-es-ink">@subscription.BufferSize buffer / @subscription.LiveBufferSize live / @subscription.ReadBatchSize batch</p>
				</div>
				<div class="rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4">
					<p class="text-xs font-black uppercase tracking-[0.18em] text-es-muted">Checkpointing</p>
					<p class="mt-2 font-mono text-es-ink">@subscription.CheckPointAfterMilliseconds ms / @subscription.MinCheckPointCount-@subscription.MaxCheckPointCount events</p>
				</div>
				<div class="rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4">
					<p class="text-xs font-black uppercase tracking-[0.18em] text-es-muted">Options</p>
					<p class="mt-2 font-mono text-es-ink">Links: @subscription.ResolveLinkTos / Extra stats: @subscription.ExtraStatistics</p>
				</div>
			</div>
		</article>

		<aside class="grid gap-5">
			<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
				<StatusBadge Label="Actions" Tone="warn" />
				<h2 class="mt-4 text-2xl font-black tracking-tight text-es-ink">Manage subscription</h2>
				<div class="mt-5 flex flex-wrap gap-2">
					<a class="rounded-2xl bg-es-ink px-5 py-3 text-sm font-black text-white shadow-lg shadow-es-ink/15 transition hover:bg-es-green" href="@subscription.UiEditHref">Edit</a>
					<a class="rounded-2xl border border-es-ink/10 bg-white px-5 py-3 text-sm font-black text-es-ink transition hover:border-es-green/30 hover:text-es-forest" href="@subscription.UiParkedHref">View parked</a>
					<a class="rounded-2xl border border-red-200 bg-red-50 px-5 py-3 text-sm font-black text-red-800 transition hover:bg-red-100" href="@subscription.UiDeleteHref">Delete</a>
				</div>
				<a class="mt-4 inline-flex text-sm font-bold text-es-green transition hover:text-es-forest" href="@subscription.DetailHref" target="_blank" rel="noopener noreferrer">Raw details</a>
			</article>

			<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
				<StatusBadge Label="Parked queue" Tone="bad" />
				<h2 class="mt-4 text-2xl font-black tracking-tight text-es-ink">Replay parked messages</h2>
				<p class="mt-3 text-sm leading-6 text-es-muted">Replay all parked messages, or stop at a specific parked event number.</p>
				@if (Result is not null)
				{
					<p class="mt-5 rounded-2xl border @(Result.Success ? "border-es-green/25 bg-es-green/10 text-es-forest" : "border-red-200 bg-red-50 text-red-800") p-4 text-sm font-bold">@Result.Message</p>
				}
				<EditForm Model="ReplayInput" FormName="subscription-detail-replay" OnValidSubmit="ReplayParked">
					<AntiforgeryToken />
					<label class="mt-5 block text-sm font-bold text-es-muted">
						Stop at event number
						<InputNumber class="mt-2 w-full rounded-2xl border border-es-ink/10 bg-white px-4 py-3 font-mono text-es-ink outline-none transition focus:border-es-green focus:ring-4 focus:ring-es-green/15" @bind-Value="ReplayInput.StopAt" />
					</label>
					<button class="mt-4 rounded-2xl bg-es-green px-5 py-3 text-sm font-black text-white shadow-lg shadow-es-green/20 transition hover:bg-es-forest" type="submit">Replay parked</button>
				</EditForm>
			</article>
		</aside>
	</section>
}

@code {
	[Parameter] public string StreamId { get; set; } = "";
	[Parameter] public string GroupName { get; set; } = "";

	[SupplyParameterFromForm(FormName = "subscription-detail-replay")]
	private ReplayParkedInput ReplayInput { get; set; } = new();

	private SubscriptionDetailPage Page { get; set; }
	private SubscriptionCommandResult Result { get; set; }

	protected override async Task OnParametersSetAsync() {
		var requestedStream = StreamId;
		var requestedGroup = GroupName;
		Page = null;
		Result = null;

		try {
			var page = await SubscriptionBrowser.Read(requestedStream, requestedGroup);
			if (requestedStream == StreamId && requestedGroup == GroupName)
				Page = page;
		} catch (OperationCanceledException) {
			throw;
		} catch (Exception ex) {
			if (requestedStream == StreamId && requestedGroup == GroupName)
				Page = SubscriptionDetailPage.Unavailable(requestedStream, requestedGroup, $"Failed to load subscription: {UiMessages.Friendly(ex)}");
		}
	}

	private async Task ReplayParked() {
		if (Page?.Subscription is not { } subscription) {
			Result = SubscriptionCommandResult.Failure(StreamId, GroupName, "Subscription details are not loaded.");
			return;
		}

		try {
			Result = await SubscriptionBrowser.ReplayParked(subscription.StreamId, subscription.GroupName, ReplayInput.StopAt);
		} catch (OperationCanceledException) {
			Result = SubscriptionCommandResult.Failure(subscription.StreamId, subscription.GroupName, "Replay parked was canceled.");
		} catch (Exception ex) {
			Result = SubscriptionCommandResult.Failure(subscription.StreamId, subscription.GroupName, $"Failed to replay parked messages: {UiMessages.Friendly(ex)}");
		}
	}

	private sealed class ReplayParkedInput {
		public long? StopAt { get; set; }
	}
}
