@page "/ui/projections/{*Name}"
@inject ProjectionBrowserService Projections

<PageTitle>@Name - EventStore UI</PageTitle>

<section class="max-w-5xl">
	<a class="text-sm font-bold text-es-green hover:text-es-forest" href="/ui/projections">&lt;- Projections</a>
	<p class="mt-6 text-sm font-black uppercase tracking-[0.28em] text-es-green">Projection detail</p>
	<h1 class="mt-4 break-words text-5xl font-black tracking-tight text-es-ink sm:text-6xl">@Name</h1>
	<p class="mt-5 text-lg leading-8 text-es-muted">Read-only status, progress, checkpoint, and raw diagnostic handoffs for this projection.</p>
</section>

<section class="mt-8">
	@if (Page is null)
	{
		<div class="rounded-[1.75rem] border border-white/80 bg-white/80 p-6 text-es-muted shadow-[0_18px_60px_rgba(23,32,51,0.08)]">
			Loading projection...
		</div>
	}
	else if (!Page.HasProjection)
	{
		<div class="rounded-[1.75rem] border border-white/80 bg-white/80 p-6 text-es-muted shadow-[0_18px_60px_rgba(23,32,51,0.08)]">
			@Page.Message
		</div>
	}
	else
	{
		var projection = Page.Projection;
		<div class="grid gap-5 lg:grid-cols-[0.9fr_1.1fr]">
			<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
				<div class="flex flex-wrap gap-2">
					<StatusBadge Label="@projection.StatusLabel" Tone="@projection.StatusTone" />
					<StatusBadge Label="@projection.EnabledLabel" Tone="@projection.EnabledTone" />
					<StatusBadge Label="@projection.Mode" Tone="muted" />
				</div>
				<h2 class="mt-5 text-3xl font-black tracking-tight text-es-ink">@projection.EffectiveName</h2>
				@if (!string.IsNullOrWhiteSpace(projection.StateReason))
				{
					<p class="mt-4 rounded-2xl border border-amber-200 bg-amber-50 p-4 leading-7 text-amber-900">@projection.StateReason</p>
				}
				<dl class="mt-6 grid gap-4 text-sm sm:grid-cols-2">
					<div>
						<dt class="font-black text-es-ink">Progress</dt>
						<dd class="mt-1 font-mono text-es-muted">@projection.ProgressLabel</dd>
					</div>
					<div>
						<dt class="font-black text-es-ink">Checkpoint</dt>
						<dd class="mt-1 font-mono text-es-muted">@(string.IsNullOrWhiteSpace(projection.CheckpointStatus) ? "n/a" : projection.CheckpointStatus)</dd>
					</div>
					<div class="sm:col-span-2">
						<dt class="font-black text-es-ink">Position</dt>
						<dd class="mt-1 break-words font-mono text-es-muted">@(string.IsNullOrWhiteSpace(projection.Position) ? "n/a" : projection.Position)</dd>
					</div>
					<div class="sm:col-span-2">
						<dt class="font-black text-es-ink">Last checkpoint</dt>
						<dd class="mt-1 break-words font-mono text-es-muted">@(string.IsNullOrWhiteSpace(projection.LastCheckpoint) ? "No checkpoint" : projection.LastCheckpoint)</dd>
					</div>
				</dl>
			</article>

			<div class="grid gap-4 sm:grid-cols-2">
				<MetricCard Label="Events" Value="@projection.EventsProcessedAfterRestart.ToString()" />
				<MetricCard Label="Buffered" Value="@projection.BufferedEvents.ToString()" Tone="muted" />
				<MetricCard Label="Reads" Value="@projection.ReadsInProgress.ToString()" Tone="muted" />
				<MetricCard Label="Writes" Value="@projection.WritesInProgress.ToString()" Tone="muted" />
				<MetricCard Label="Partitions" Value="@projection.PartitionsCached.ToString()" Tone="muted" />
				<MetricCard Label="Core ms" Value="@projection.CoreProcessingTime.ToString()" Tone="muted" />
			</div>
		</div>

		<section class="mt-6 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
			<SurfaceCard Eyebrow="Raw" Title="Statistics" Description="Open the projection statistics payload returned by the node." Href="@projection.RawStatisticsHref" LinkText="Open statistics" Target="_blank" />
			<SurfaceCard Eyebrow="Raw" Title="State" Description="Inspect the projection state payload when the projection exposes one." Href="@projection.RawStateHref" LinkText="Open state" Target="_blank" />
			<SurfaceCard Eyebrow="Raw" Title="Result" Description="Inspect the projection result payload when the projection exposes one." Href="@projection.RawResultHref" LinkText="Open result" Target="_blank" />
			<SurfaceCard Eyebrow="Raw" Title="Query" Description="Review the projection query and configuration response." Href="@projection.RawQueryHref" LinkText="Open query" Target="_blank" />
			<SurfaceCard Eyebrow="Raw" Title="Config" Description="Review the projection configuration response." Href="@projection.RawConfigHref" LinkText="Open config" Target="_blank" />
			@if (!string.IsNullOrWhiteSpace(projection.ResultStreamHref))
			{
				<SurfaceCard Eyebrow="Stream" Title="Result stream" Description="Inspect the stream that receives this projection output." Href="@projection.ResultStreamHref" LinkText="Open stream" />
			}
		</section>
	}
</section>

@code {
	[Parameter] public string Name { get; set; } = "";

	private ProjectionDetailPage Page { get; set; }

	protected override async Task OnParametersSetAsync() {
		Page = await Projections.ReadProjection(Name);
	}
}
