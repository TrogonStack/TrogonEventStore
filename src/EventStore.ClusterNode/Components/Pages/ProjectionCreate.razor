@page "/ui/projections/new"
@inject ProjectionBrowserService Projections
@inject NavigationManager Navigation
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>New Projection - EventStore UI</PageTitle>

<section class="max-w-5xl">
	<a class="text-sm font-bold text-es-green transition hover:text-es-forest" href="/ui/projections">Back to projections</a>
	<p class="mt-6 text-sm font-black uppercase tracking-[0.28em] text-es-green">New projection</p>
	<h1 class="mt-4 text-5xl font-black tracking-tight text-es-ink sm:text-6xl">Create a custom projection.</h1>
	<p class="mt-5 text-lg leading-8 text-es-muted">Create one-time or continuous JavaScript projections with the same checkpointing, emitting, and startup controls as the legacy page.</p>
</section>

<section class="mt-8 grid gap-5 xl:grid-cols-[1.2fr_0.8fr]">
	<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
		<EditForm Model="Input" FormName="projection-create" OnValidSubmit="CreateProjection">
			<AntiforgeryToken />
			<DataAnnotationsValidator />

			<div class="grid gap-4 md:grid-cols-2">
				<label class="text-sm font-bold text-es-muted">
					Name
					<InputText class="mt-2 w-full rounded-2xl border border-es-ink/10 bg-white px-4 py-3 font-mono text-es-ink outline-none transition focus:border-es-green focus:ring-4 focus:ring-es-green/15" @bind-Value="Input.Name" />
					<ValidationMessage For="() => Input.Name" />
				</label>
				<label class="text-sm font-bold text-es-muted">
					Mode
					<InputSelect class="mt-2 w-full rounded-2xl border border-es-ink/10 bg-white px-4 py-3 text-es-ink outline-none transition focus:border-es-green focus:ring-4 focus:ring-es-green/15" @bind-Value="Input.Mode">
						<option value="@ProjectionCreateMode.OneTime">One-time</option>
						<option value="@ProjectionCreateMode.Continuous">Continuous</option>
					</InputSelect>
				</label>
			</div>

			<div class="mt-5 grid gap-3 rounded-2xl border border-es-ink/10 bg-es-ink/5 p-4 md:grid-cols-2">
				<label class="flex items-center gap-3 text-sm font-bold text-es-ink">
					<InputCheckbox @bind-Value="Input.Enabled" />
					Enabled after create
				</label>
				<label class="flex items-center gap-3 text-sm font-bold text-es-ink">
					<InputCheckbox @bind-Value="Input.CheckpointsEnabled" />
					Checkpoints enabled
				</label>
				<label class="flex items-center gap-3 text-sm font-bold text-es-ink">
					<InputCheckbox @bind-Value="Input.EmitEnabled" />
					Emit enabled
				</label>
				<label class="flex items-center gap-3 text-sm font-bold text-es-ink">
					<InputCheckbox @bind-Value="Input.TrackEmittedStreams" />
					Track emitted streams
				</label>
			</div>

			<label class="mt-5 block text-sm font-black uppercase tracking-[0.22em] text-es-green" for="projection-source">Source</label>
			<InputTextArea id="projection-source" class="mt-4 min-h-96 w-full rounded-2xl border border-es-ink/10 bg-es-ink px-4 py-3 font-mono text-sm text-white outline-none transition placeholder:text-white/40 focus:border-es-green focus:ring-4 focus:ring-es-green/15" @bind-Value="Input.Query" />
			<ValidationMessage For="() => Input.Query" />

			@if (Result is not null && !Result.Success)
			{
				<p class="mt-5 rounded-2xl border border-red-200 bg-red-50 p-4 text-sm font-bold text-red-800">@Result.Message</p>
			}

			<div class="mt-5 flex flex-wrap gap-2">
				<button class="rounded-2xl bg-es-ink px-5 py-3 text-sm font-black text-white shadow-lg shadow-es-ink/15 transition hover:bg-es-green" type="submit">Create projection</button>
				<a class="rounded-2xl border border-es-ink/10 bg-white px-5 py-3 text-sm font-black text-es-ink transition hover:border-es-green/30 hover:text-es-forest" href="/ui/projections">Cancel</a>
			</div>
		</EditForm>
	</article>

	<aside class="grid gap-5">
		<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
			<StatusBadge Label="Continuous projections" Tone="warn" />
			<h2 class="mt-4 text-2xl font-black tracking-tight text-es-ink">Checkpoint rule</h2>
			<p class="mt-3 text-sm leading-6 text-es-muted">Continuous projections require checkpoints. If continuous mode is selected, the server-side request preserves that rule even if the checkbox is cleared.</p>
		</article>
		<article class="rounded-[2rem] border border-white/80 bg-white/85 p-6 shadow-[0_20px_70px_rgba(23,32,51,0.09)]">
			<StatusBadge Label="Standard" Tone="muted" />
			<h2 class="mt-4 text-2xl font-black tracking-tight text-es-ink">Need a built-in handler?</h2>
			<p class="mt-3 text-sm leading-6 text-es-muted">Use the standard projection page when the handler type should be one of the built-in native projection handlers.</p>
			<a class="mt-5 inline-flex rounded-2xl border border-es-ink/10 bg-white px-5 py-3 text-sm font-black text-es-ink transition hover:border-es-green/30 hover:text-es-forest" href="/ui/projections/standard">Create standard projection</a>
		</article>
	</aside>
</section>

@code {
	private const string DefaultQuery = "fromAll().when({\n  $init: function () { return {}; },\n  $any: function (state, event) {\n    return state;\n  }\n});";

	[SupplyParameterFromForm(FormName = "projection-create")]
	private ProjectionCreateInput Input { get; set; } = new();

	private ProjectionCommandResult Result { get; set; }

	private async Task CreateProjection() {
		var redirectTo = "";
		try {
			Result = await Projections.Create(Input.ToRequest());
			if (Result.Success)
				redirectTo = $"/ui/projections/{Uri.EscapeDataString(Result.Name)}";
		} catch (OperationCanceledException) {
			Result = ProjectionCommandResult.Failure(Input.Name, "Projection creation was canceled.");
		} catch (Exception ex) {
			Result = ProjectionCommandResult.Failure(Input.Name, $"Failed to create projection: {FriendlyMessage(ex)}");
		}

		if (!string.IsNullOrWhiteSpace(redirectTo))
			Navigation.NavigateTo(redirectTo);
	}

	private static string FriendlyMessage(Exception ex) =>
		string.IsNullOrWhiteSpace(ex.Message) ? ex.GetType().Name : ex.Message;

	private sealed class ProjectionCreateInput {
		[Required(ErrorMessage = "Enter a projection name.")]
		public string Name { get; set; } = "";

		public ProjectionCreateMode Mode { get; set; } = ProjectionCreateMode.OneTime;
		public bool Enabled { get; set; } = true;
		public bool CheckpointsEnabled { get; set; }
		public bool EmitEnabled { get; set; }
		public bool TrackEmittedStreams { get; set; }

		[Required(ErrorMessage = "Enter projection source.")]
		public string Query { get; set; } = DefaultQuery;

		public ProjectionCreateRequest ToRequest() =>
			new(
				Mode,
				Name,
				Query,
				Enabled,
				CheckpointsEnabled,
				EmitEnabled,
				TrackEmittedStreams);
	}
}
